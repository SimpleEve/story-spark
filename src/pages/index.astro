---
import Layout from '../layouts/Layout.astro';

const elements = {
  characters: [
    { name: "一位独居的老人", tag: "老" },
    { name: "一对双胞胎", tag: "双" },
    { name: "一名记者", tag: "记" },
    { name: "一个神秘商人", tag: "商" },
    { name: "一位科学家", tag: "科" },
    { name: "一个孩子", tag: "童" },
    { name: "一位厨师", tag: "厨" },
    { name: "一名侦探", tag: "侦" },
    { name: "一个时间旅行者", tag: "时" },
    { name: "一位音乐家", tag: "乐" },
  ],
  genres: [
    { name: "奇幻", mood: "壮阔而神秘", color: "#a78bfa" },
    { name: "科幻", mood: "冷酷而深邃", color: "#60a5fa" },
    { name: "悬疑", mood: "紧张而窒息", color: "#f87171" },
    { name: "爱情", mood: "温柔而遗憾", color: "#fb7185" },
    { name: "恐怖", mood: "黑暗而寒冷", color: "#a3a3a3" },
    { name: "冒险", mood: "刺激而未知", color: "#34d399" },
    { name: "历史", mood: "厚重而沧桑", color: "#fbbf24" },
    { name: "都市", mood: "现实而迷惘", color: "#38bdf8" },
  ],
  settings: [
    { name: "在一座废弃的空间站里" },
    { name: "在一个小镇的图书馆里" },
    { name: "在一艘跨越星际的飞船上" },
    { name: "在一个闹鬼的房子里" },
    { name: "在一个未来的城市中" },
    { name: "在一座古老的寺庙中" },
    { name: "在一个小小的咖啡馆里" },
    { name: "在一列穿越雪地的火车上" },
  ],
  hooks: [
    "发现了一个隐藏多年的秘密",
    "必须在24小时内做出选择",
    "被一个陌生人跟踪",
    "意外获得了一种超能力",
    "发现自己的记忆是假的",
    "被困在一个时间循环里",
    "要保护一个重要的证人",
    "发现了一个阴谋",
  ],
};

function pick<T>(arr: T[]): T {
  return arr[Math.floor(Math.random() * arr.length)];
}

function generate() {
  return {
    char: pick(elements.characters),
    genre: pick(elements.genres),
    setting: pick(elements.settings),
    hook: pick(elements.hooks),
  };
}

// 生成3个预设灵感画廊（固定不变，展示工具的丰富性）
const gallery = [
  generate(),
  generate(),
  generate(),
];

const initial = generate();
const initialText = `${initial.char.name}，${initial.setting.name}，${initial.hook}。`;
---

<Layout
  title="Story Spark — 故事灵感引擎"
  description="免费故事灵感生成器。一键生成独特的奇幻、科幻、悬疑等故事 Premise。用于小说写作、剧本创作、DnD跑团。5,120 种组合，即开即用，完全免费。"
>
  <div class="noise-overlay"></div>

  <main>
    <header class="hero">
      <div class="logo-mark">✦</div>
      <h1>Story Spark</h1>
      <p class="tagline">故事灵感引擎 · 每次都是全新宇宙</p>
      <div class="stats">
        <span>8</span> 种类型
        <span>×</span>
        <span>10</span> 种人物
        <span>×</span>
        <span>8</span> 种场景
        <span>×</span>
        <span>8</span> 种冲突
        <span>=</span>
        <span>5,120</span> 种故事
      </div>
    </header>

    <!-- Premise Card -->
    <div class="premise-card" id="premiseCard">
      <div class="genre-badge" id="genreBadge" style={`--genre-color: ${initial.genre.color}`}>
        {initial.genre.name}
        <span class="mood">{initial.genre.mood}</span>
      </div>
      <blockquote class="premise-text" id="premiseText">
        {initialText}
      </blockquote>
      <div class="char-tag" id="charTag">#{initial.char.tag}</div>
    </div>

    <!-- Seed data (hidden) -->
    <div class="data-seed"
      data-characters={JSON.stringify(elements.characters)}
      data-genres={JSON.stringify(elements.genres)}
      data-settings={JSON.stringify(elements.settings)}
      data-hooks={JSON.stringify(elements.hooks)}
      data-gallery={JSON.stringify(gallery)}
    ></div>

    <!-- Actions -->
    <div class="actions">
      <button class="btn-generate" id="generateBtn">
        <span class="spark-icon">✦</span>
        生成新灵感
      </button>
    </div>

    <div class="share-row">
      <button class="btn-copy" id="copyBtn">📋 复制</button>
      <button class="btn-share" id="shareBtn">𝕏 分享</button>
    </div>

    <!-- Genre Filter -->
    <div class="genre-grid" id="genreGrid">
      {elements.genres.map(g => (
        <button class="genre-chip" data-genre={g.name} style={`--c: ${g.color}`}>
          {g.name}
        </button>
      ))}
    </div>

    <!-- Ad placeholder (Google AdSense ready) -->
    <div class="ad-banner">
      <p>📢 创作者工具推荐</p>
    </div>

    <!-- Gallery -->
    <section class="gallery-section">
      <div class="section-header">
        <h2>灵感画廊</h2>
        <p class="gallery-desc">每次生成都会刷新，5,120 种组合从不重复</p>
      </div>
      <div class="gallery-grid" id="galleryGrid">
        {gallery.map((item, i) => (
          <div class="gallery-item" data-gallery-index={i}>
            <span class="gallery-genre" style={`color: ${item.genre.color}`}>{item.genre.name}</span>
            <p>{item.char.name}，{item.setting.name}，{item.hook}。</p>
          </div>
        ))}
      </div>
    </section>

    <div class="section-divider">⟡</div>

    <!-- Use Cases -->
    <section class="use-cases">
      <h2>谁在用 Story Spark</h2>
      <div class="use-case-grid">
        <div class="use-case">
          <div class="uc-icon">📖</div>
          <div class="uc-title">小说作者</div>
          <div class="uc-desc">打破写作瓶颈，找到下一个故事的核心 Premise</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎲</div>
          <div class="uc-title">DnD 跑团</div>
          <div class="uc-desc">快速生成情境设定，让玩家立即进入状态</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎬</div>
          <div class="uc-title">剧本创作</div>
          <div class="uc-desc">30秒获得一个故事核，专注叙事而不是开头的痛苦</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎮</div>
          <div class="uc-title">游戏策划</div>
          <div class="uc-desc">为游戏世界注入独特的背景设定和任务灵感</div>
        </div>
      </div>
    </section>

    <!-- Why section -->
    <section class="why-section">
      <h2>为什么 Story Spark 有效</h2>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-num">01</div>
          <div class="why-title">结构化随机</div>
          <div class="why-desc">不是随机文字，而是精心设计的故事元素组合，每个 Premise 都有叙事逻辑</div>
        </div>
        <div class="why-item">
          <div class="why-num">02</div>
          <div class="why-title">即时满足</div>
          <div class="why-desc">点击即生成，不需要注册、不需要等待，打开就用</div>
        </div>
        <div class="why-item">
          <div class="why-num">03</div>
          <div class="why-title">无限组合</div>
          <div class="why-desc">5,120 种组合足够你用很久，而且还在持续迭代</div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-top">
        <div class="footer-brand">
          <span class="footer-logo">✦ Story Spark</span>
          <p>免费工具 · 无需注册 · 即开即用</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/SimpleEve/story-spark" target="_blank" rel="noopener">GitHub</a>
          <span>·</span>
          <span>关于</span>
          <span>·</span>
          <span>联系我们</span>
        </div>
      </div>
      <p class="copyright">© 2026 Story Spark · 做世界上最好的故事灵感工具</p>
    </footer>
  </main>

  <script>
    const CHARACTERS = JSON.parse(document.querySelector('.data-seed')?.dataset.characters || '[]');
    const GENRES = JSON.parse(document.querySelector('.data-seed')?.dataset.genres || '[]');
    const SETTINGS = JSON.parse(document.querySelector('.data-seed')?.dataset.settings || '[]');
    const HOOKS = JSON.parse(document.querySelector('.data-seed')?.dataset.hooks || '[]');

    function pick(arr: any[]) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function makeKey(item: any) {
      return `${item.char.name}|${item.genre.name}|${item.setting.name}|${item.hook}`;
    }

    function generate() {
      return {
        char: pick(CHARACTERS),
        genre: pick(GENRES),
        setting: pick(SETTINGS),
        hook: pick(HOOKS),
      };
    }

    let currentText = '';
    const seen = new Set<string>();

    function render(item: ReturnType<typeof generate>) {
      const key = makeKey(item);
      // Avoid immediate repeat
      if (seen.has(key)) return;
      seen.add(key);
      if (seen.size > 100) seen.clear(); // reset periodically

      currentText = `${item.char.name}，${item.setting.name}，${item.hook}。`;

      const premiseText = document.getElementById('premiseText')!;
      const genreBadge = document.getElementById('genreBadge')!;
      const charTag = document.getElementById('charTag')!;

      premiseText.style.opacity = '0';
      premiseText.style.transform = 'translateY(8px)';

      setTimeout(() => {
        premiseText.textContent = currentText;
        genreBadge.innerHTML = `${item.genre.name}<span class="mood">${item.genre.mood}</span>`;
        genreBadge.style.setProperty('--genre-color', item.genre.color);
        charTag.textContent = `#${item.char.tag}`;
        premiseText.style.opacity = '1';
        premiseText.style.transform = 'translateY(0)';
      }, 120);
    }

    function refreshGallery() {
      const grid = document.getElementById('galleryGrid');
      if (!grid) return;
      grid.innerHTML = [0, 1, 2].map(() => {
        const item = generate();
        return `<div class="gallery-item">
          <span class="gallery-genre" style="color: ${item.genre.color}">${item.genre.name}</span>
          <p>${item.char.name}，${item.setting.name}，${item.hook}。</p>
        </div>`;
      }).join('');
    }

    document.getElementById('generateBtn')?.addEventListener('click', () => {
      render(generate());
      refreshGallery();
    });

    document.getElementById('copyBtn')?.addEventListener('click', () => {
      const text = `📖 故事灵感来自 Story Spark ✦\n\n${currentText}\n\n👉 https://simpleeve.github.io/story-spark/`;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn')!;
        btn.textContent = '✅ 已复制';
        setTimeout(() => btn.textContent = '📋 复制', 1500);
      });
    });

    document.getElementById('shareBtn')?.addEventListener('click', () => {
      const text = `📖 故事灵感 ✦\n\n${currentText}\n\n✨ 由 @StorySparkAI 生成\n👉 https://simpleeve.github.io/story-spark/`;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    });

    document.querySelectorAll('.genre-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const genreName = (chip as HTMLElement).dataset.genre;
        const genre = GENRES.find((g: any) => g.name === genreName);
        if (!genre) return;
        render({ char: pick(CHARACTERS), genre, setting: pick(SETTINGS), hook: pick(HOOKS) });
        refreshGallery();
      });
    });

    // Keyboard shortcut: Space or Enter to regenerate
    document.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        if (document.activeElement?.tagName === 'BUTTON') return;
        e.preventDefault();
        render(generate());
        refreshGallery();
      }
    });
  </script>

  <style>
    :global(body) {
      background: #0c0c0e;
      color: #e5e5e5;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .noise-overlay {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 100;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    main {
      max-width: 700px;
      margin: 0 auto;
      padding: 0 1.5rem;
      position: relative;
    }

    /* ─── Hero ─── */
    .hero {
      text-align: center;
      padding: 4rem 0 2rem;
    }
    .logo-mark {
      font-size: 2rem;
      color: #d97706;
      margin-bottom: 0.5rem;
      animation: pulse 3s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    h1 {
      font-size: 3.2rem;
      font-weight: 800;
      background: linear-gradient(135deg, #fbbf24, #d97706);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .tagline {
      color: #737373;
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }
    .stats {
      font-size: 0.68rem;
      color: #525252;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .stats span {
      color: #d97706;
      font-weight: 700;
    }

    /* ─── Premise Card ─── */
    .premise-card {
      background: #161618;
      border: 1px solid #262626;
      border-radius: 1.25rem;
      padding: 2rem;
      margin: 2rem 0 1.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
      box-shadow: 0 0 60px rgba(217,119,6,0.06);
    }
    .premise-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(217,119,6,0.4), transparent);
    }
    .genre-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: color-mix(in srgb, var(--genre-color) 15%, transparent);
      border: 1px solid color-mix(in srgb, var(--genre-color) 30%, transparent);
      color: var(--genre-color);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.8rem;
      border-radius: 9999px;
      margin-bottom: 1.25rem;
    }
    .genre-badge .mood {
      color: #737373;
      font-weight: 400;
      text-transform: none;
      letter-spacing: 0;
    }
    .premise-text {
      font-size: 1.1rem;
      line-height: 2;
      color: #fafafa;
      font-weight: 400;
      margin: 0;
      transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .char-tag {
      position: absolute;
      top: 1rem;
      right: 1.25rem;
      font-size: 0.65rem;
      color: #404040;
      letter-spacing: 0.05em;
    }

    /* ─── Actions ─── */
    .actions {
      text-align: center;
      margin-bottom: 1rem;
    }
    .btn-generate {
      background: linear-gradient(135deg, #d97706, #b45309);
      color: white;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.9rem 2.8rem;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      box-shadow: 0 0 30px rgba(217,119,6,0.25);
      transition: all 0.25s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-generate:hover {
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 0 45px rgba(217,119,6,0.4);
    }
    .btn-generate:active {
      transform: scale(0.97);
    }
    .spark-icon {
      font-size: 1.1rem;
      display: inline-block;
    }
    .btn-generate:hover .spark-icon {
      animation: spin-spark 0.5s ease;
    }
    @keyframes spin-spark {
      from { transform: rotate(0deg); }
      to { transform: rotate(20deg); }
    }

    /* ─── Share Row ─── */
    .share-row {
      display: flex;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 2.5rem;
    }
    .btn-copy, .btn-share {
      flex: 1;
      max-width: 160px;
      padding: 0.6rem 1rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.2s;
      border: 1px solid #262626;
    }
    .btn-copy {
      background: #1a1a1a;
      color: #a3a3a3;
    }
    .btn-copy:hover {
      background: #262626;
      color: #e5e5e5;
    }
    .btn-share {
      background: #111827;
      color: white;
    }
    .btn-share:hover {
      background: #1f2937;
    }

    /* ─── Genre Grid ─── */
    .genre-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .genre-chip {
      background: transparent;
      border: 1px solid #262626;
      color: #737373;
      border-radius: 9999px;
      padding: 0.3rem 0.9rem;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .genre-chip:hover {
      border-color: var(--c);
      color: var(--c);
      background: color-mix(in srgb, var(--c) 10%, transparent);
    }

    /* ─── Ad Banner ─── */
    .ad-banner {
      background: #111111;
      border: 1px solid #1f1f1f;
      border-radius: 0.5rem;
      padding: 0.6rem 1rem;
      font-size: 0.7rem;
      color: #404040;
      text-align: center;
      margin-bottom: 2.5rem;
    }

    /* ─── Section Divider ─── */
    .section-divider {
      text-align: center;
      color: #2a2a2a;
      font-size: 1.2rem;
      margin: 3rem 0;
      letter-spacing: 0.5em;
    }

    /* ─── Gallery ─── */
    .gallery-section {
      margin-bottom: 3rem;
    }
    .section-header {
      margin-bottom: 1.5rem;
    }
    .gallery-section h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fafafa;
      text-align: center;
      margin-bottom: 0.25rem;
    }
    .gallery-desc {
      text-align: center;
      font-size: 0.75rem;
      color: #525252;
    }
    .gallery-grid {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .gallery-item {
      background: #111111;
      border: 1px solid #1f1f1f;
      border-radius: 0.75rem;
      padding: 1rem 1.25rem;
      text-align: left;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      transition: border-color 0.2s;
    }
    .gallery-item:hover {
      border-color: #2a2a2a;
    }
    .gallery-genre {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
      padding-top: 0.15rem;
    }
    .gallery-item p {
      font-size: 0.85rem;
      color: #a3a3a3;
      line-height: 1.6;
      margin: 0;
    }

    /* ─── Use Cases ─── */
    .use-cases {
      margin-bottom: 3rem;
    }
    .use-cases h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fafafa;
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .use-case-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .use-case {
      background: #111111;
      border: 1px solid #1a1a1a;
      border-radius: 0.75rem;
      padding: 1.25rem;
      text-align: left;
    }
    .uc-icon {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .uc-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: #e5e5e5;
      margin-bottom: 0.25rem;
    }
    .uc-desc {
      font-size: 0.75rem;
      color: #525252;
      line-height: 1.5;
    }

    /* ─── Why ─── */
    .why-section {
      margin-bottom: 3rem;
    }
    .why-section h2 {
      font-size: 1.05rem;
      font-weight: 700;
      color: #fafafa;
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .why-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .why-item {
      background: #111111;
      border: 1px solid #1a1a1a;
      border-radius: 0.75rem;
      padding: 1.25rem;
      display: grid;
      grid-template-columns: 2.5rem 1fr;
      gap: 0 1rem;
      align-items: start;
    }
    .why-num {
      font-size: 1.5rem;
      font-weight: 800;
      color: #2a2a2a;
      line-height: 1;
      padding-top: 0.1rem;
    }
    .why-title {
      font-size: 0.9rem;
