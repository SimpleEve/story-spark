---
import Layout from '../layouts/Layout.astro';

const elements = {
  characters: [
    { name: "一位独居的老人", tag: "老" },
    { name: "一对双胞胎", tag: "双" },
    { name: "一名记者", tag: "记" },
    { name: "一个神秘商人", tag: "商" },
    { name: "一位科学家", tag: "科" },
    { name: "一个孩子", tag: "童" },
    { name: "一位厨师", tag: "厨" },
    { name: "一名侦探", tag: "侦" },
    { name: "一个时间旅行者", tag: "时" },
    { name: "一位音乐家", tag: "乐" },
  ],
  genres: [
    { name: "奇幻", mood: "壮阔而神秘", color: "#a78bfa" },
    { name: "科幻", mood: "冷酷而深邃", color: "#60a5fa" },
    { name: "悬疑", mood: "紧张而窒息", color: "#f87171" },
    { name: "爱情", mood: "温柔而遗憾", color: "#fb7185" },
    { name: "恐怖", mood: "黑暗而寒冷", color: "#a3a3a3" },
    { name: "冒险", mood: "刺激而未知", color: "#34d399" },
    { name: "历史", mood: "厚重而沧桑", color: "#fbbf24" },
    { name: "都市", mood: "现实而迷惘", color: "#38bdf8" },
  ],
  settings: [
    { name: "在一座废弃的空间站里" },
    { name: "在一个小镇的图书馆里" },
    { name: "在一艘跨越星际的飞船上" },
    { name: "在一个闹鬼的房子里" },
    { name: "在一个未来的城市中" },
    { name: "在一座古老的寺庙中" },
    { name: "在一个小小的咖啡馆里" },
    { name: "在一列穿越雪地的火车上" },
  ],
  hooks: [
    "发现了一个隐藏多年的秘密",
    "必须在24小时内做出选择",
    "被一个陌生人跟踪",
    "意外获得了一种超能力",
    "发现自己的记忆是假的",
    "被困在一个时间循环里",
    "要保护一个重要的证人",
    "发现了一个阴谋",
  ],
};

function pick<T>(arr: T[]): T {
  return arr[Math.floor(Math.random() * arr.length)];
}

function generate() {
  return {
    char: pick(elements.characters),
    genre: pick(elements.genres),
    setting: pick(elements.settings),
    hook: pick(elements.hooks),
  };
}

// Generate 3 gallery items (fixed, show richness)
const gallery = [
  generate(),
  generate(),
  generate(),
];

const initial = generate();
const initialText = `${initial.char.name}，${initial.setting.name}，${initial.hook}。`;
---

<Layout
  title="Story Spark — 故事灵感引擎"
  description="免费故事灵感生成器。一键生成独特的奇幻、科幻、悬疑等故事 Premise。用于小说写作、剧本创作、DnD跑团。5,120 种组合，即开即用，完全免费。"
>
  <main>
    <!-- HERO -->
    <header class="hero">
      <div class="hero-eyebrow">CREATIVE WRITING TOOL</div>
      <h1 class="hero-title">STORY<br/>SPARK</h1>
      <p class="hero-sub">故事灵感引擎 · 每次都是全新宇宙</p>
      <div class="daily-strip">
        <div class="daily-story-card">
          <div class="mini-label">今日故事</div>
          <p id="dailyStoryText">{initialText}</p>
        </div>
        <div class="streak-card" id="streakCard">
          <div class="mini-label">访问 Streak</div>
          <div class="streak-value"><span id="streakCount">1</span> 天</div>
          <p id="streakHint">今天第一次访问，开始积累灵感习惯。</p>
        </div>
      </div>
      <div class="hero-stats">
        <span class="stat-num">8</span><span class="stat-label">类型</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">10</span><span class="stat-label">人物</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">8</span><span class="stat-label">场景</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">8</span><span class="stat-label">冲突</span>
        <span class="stat-sep">=</span>
        <span class="stat-num accent">5,120</span>
      </div>
    </header>

    <!-- PREMISE CARD -->
    <div class="premise-block">
      <div class="premise-card" id="premiseCard">
        <div class="premise-card-inner">
          <div class="premise-top">
            <div class="genre-badge" id="genreBadge" style={`--gc: ${initial.genre.color}`}>
              <span class="genre-name">{initial.genre.name}</span>
              <span class="genre-sep">/</span>
              <span class="genre-mood">{initial.genre.mood}</span>
            </div>
            <div class="char-tag" id="charTag">#{initial.char.tag}</div>
          </div>
          <blockquote class="premise-text" id="premiseText">
            {initialText}
          </blockquote>
          <div class="premise-meta">
            <button class="btn-favorite" id="favoriteBtn" type="button" aria-pressed="false">
              <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-heart"/></svg>
              <span>收藏灵感</span>
            </button>
            <span class="premise-status" id="favoriteStatus">未收藏</span>
          </div>
        </div>
      </div>

      <!-- Seed data (hidden) -->
      <div class="data-seed"
        data-characters={JSON.stringify(elements.characters)}
        data-genres={JSON.stringify(elements.genres)}
        data-settings={JSON.stringify(elements.settings)}
        data-hooks={JSON.stringify(elements.hooks)}
        data-gallery={JSON.stringify(gallery)}
        data-initial-text={initialText}
        data-initial-item={JSON.stringify(initial)}
      ></div>

      <!-- ACTIONS -->
      <div class="actions-row">
        <button class="btn-generate" id="generateBtn">
          <svg class="btn-icon" aria-hidden="true"><use href="#icon-spark"/></svg>
          <span>生成新灵感</span>
        </button>
      </div>

      <div class="share-row">
        <button class="btn-copy" id="copyBtn">
          <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-copy"/></svg><span>复制</span>
        </button>
        <button class="btn-share" id="shareBtn">
          <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-x"/></svg><span>分享</span>
        </button>
      </div>

      <!-- Keyboard hint -->
      <div class="kb-hint">按 <kbd>SPACE</kbd> 或 <kbd>ENTER</kbd> 快速生成</div>
    </div>

    <!-- GENRE FILTER -->
    <div class="section-label">筛选类型</div>
    <div class="genre-grid" id="genreGrid">
      {elements.genres.map(g => (
        <button class="genre-chip" data-genre={g.name} style={`--gc: ${g.color}`}>
          {g.name}
        </button>
      ))}
    </div>

    <div class="rule"></div>

    <!-- GALLERY -->
    <section class="gallery-section">
      <div class="section-label">灵感画廊</div>
      <p class="section-desc">5,120 种组合，每次刷新都不一样</p>
      <div class="gallery-grid" id="galleryGrid">
        {gallery.map((item, i) => (
          <div class="gallery-item" data-gallery-index={i}>
            <span class="gallery-genre" style={`color: ${item.genre.color}`}>{item.genre.name}</span>
            <p>{item.char.name}，{item.setting.name}，{item.hook}。</p>
          </div>
        ))}
      </div>
    </section>

    <div class="rule"></div>

    <!-- USE CASES -->
    <section class="use-cases">
      <div class="section-label">谁在用</div>
      <div class="use-case-grid">
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-book"/></svg>
          <div class="uc-title">小说作者</div>
          <div class="uc-desc">打破写作瓶颈，找到下一个故事的核心 Premise</div>
        </div>
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-dice"/></svg>
          <div class="uc-title">DnD 跑团</div>
          <div class="uc-desc">快速生成情境设定，让玩家立即进入状态</div>
        </div>
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-clapper"/></svg>
          <div class="uc-title">剧本创作</div>
          <div class="uc-desc">30秒获得一个故事核，专注叙事而不是开头的痛苦</div>
        </div>
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-gamepad"/></svg>
          <div class="uc-title">游戏策划</div>
          <div class="uc-desc">为游戏世界注入独特的背景设定和任务灵感</div>
        </div>
      </div>
    </section>

    <div class="rule"></div>

    <!-- WHY -->
    <section class="why-section">
      <div class="section-label">为什么有效</div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-num">01</div>
          <div class="why-body">
            <div class="why-title">结构化随机</div>
            <div class="why-desc">不是随机文字，而是精心设计的故事元素组合，每个 Premise 都有叙事逻辑</div>
          </div>
        </div>
        <div class="why-item">
          <div class="why-num">02</div>
          <div class="why-body">
            <div class="why-title">即时满足</div>
            <div class="why-desc">点击即生成，不需要注册、不需要等待，打开就用</div>
          </div>
        </div>
        <div class="why-item">
          <div class="why-num">03</div>
          <div class="why-body">
            <div class="why-title">无限组合</div>
            <div class="why-desc">5,120 种组合足够你用很久，而且还在持续迭代</div>
          </div>
        </div>
      </div>
    </section>

    <div class="rule"></div>

    <section class="favorites-section">
      <button class="favorites-toggle" id="favoritesToggle" type="button" aria-expanded="false">
        <span>收藏夹</span>
        <span class="favorites-summary" id="favoritesSummary">0 条已保存</span>
      </button>
      <div class="favorites-panel" id="favoritesPanel" hidden>
        <div class="favorites-actions">
          <button class="panel-btn" id="exportFavoritesBtn" type="button">导出 JSON</button>
          <button class="panel-btn" id="importFavoritesBtn" type="button">导入 JSON</button>
          <input id="importFavoritesInput" type="file" accept="application/json" hidden />
        </div>
        <p class="favorites-empty" id="favoritesEmpty">还没有收藏，先把喜欢的 premise 存下来。</p>
        <div class="favorites-list" id="favoritesList"></div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <svg style="display:inline-block;width:1em;height:1em;vertical-align:-0.1em" aria-hidden="true"><use href="#icon-spark"/></svg> STORY SPARK
          <p>免费工具 · 无需注册 · 即开即用</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/SimpleEve/story-spark" target="_blank" rel="noopener">GitHub</a>
          <span class="footer-dot">·</span>
          <a href="/story-spark/privacy">隐私政策</a>
        </div>
      </div>
      <div class="footer-copy">© 2026 Story Spark · 做世界上最好的故事灵感工具</div>
    </footer>
  </main>

  <script is:inline>
    const seed = document.querySelector('.data-seed');
    const CHARACTERS = JSON.parse(seed?.dataset.characters || '[]');
    const GENRES = JSON.parse(seed?.dataset.genres || '[]');
    const SETTINGS = JSON.parse(seed?.dataset.settings || '[]');
    const HOOKS = JSON.parse(seed?.dataset.hooks || '[]');
    const INITIAL_TEXT = seed?.dataset.initialText || '';
    const INITIAL_ITEM = JSON.parse(seed?.dataset.initialItem || 'null');
    const STORAGE_KEYS = {
      favorites: 'story-spark:favorites',
      streak: 'story-spark:streak',
    };

    function pick(arr: any[]) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function makeKey(item: any) {
      return `${item.char.name}|${item.genre.name}|${item.setting.name}|${item.hook}`;
    }

    function generate() {
      return {
        char: pick(CHARACTERS),
        genre: pick(GENRES),
        setting: pick(SETTINGS),
        hook: pick(HOOKS),
      };
    }

    function readStorage<T>(key: string, fallback: T): T {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
      } catch {
        return fallback;
      }
    }

    function writeStorage(key: string, value: unknown) {
      localStorage.setItem(key, JSON.stringify(value));
    }

    function isoToday() {
      const now = new Date();
      const offset = now.getTimezoneOffset() * 60000;
      return new Date(now.getTime() - offset).toISOString().slice(0, 10);
    }

    function parseDateValue(value: string) {
      return new Date(`${value}T00:00:00`);
    }

    function daysBetween(from: string, to: string) {
      const diff = parseDateValue(to).getTime() - parseDateValue(from).getTime();
      return Math.round(diff / 86400000);
    }

    function hashString(input: string) {
      let hash = 2166136261;
      for (let i = 0; i < input.length; i += 1) {
        hash ^= input.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
      }
      return hash >>> 0;
    }

    function seededPick<T>(arr: T[], seedValue: number) {
      return arr[seedValue % arr.length];
    }

    function getDailyStory(dateKey: string) {
      const char = seededPick(CHARACTERS, hashString(`${dateKey}:char`));
      const genre = seededPick(GENRES, hashString(`${dateKey}:genre`));
      const setting = seededPick(SETTINGS, hashString(`${dateKey}:setting`));
      const hook = seededPick(HOOKS, hashString(`${dateKey}:hook`));
      return { char, genre, setting, hook };
    }

    function toText(item: any) {
      return `${item.char.name}，${item.setting.name}，${item.hook}。`;
    }

    function sanitizeItem(item: any) {
      if (!item?.char?.name || !item?.genre?.name || !item?.setting?.name || !item?.hook) return null;
      return {
        char: {
          name: item.char.name,
          tag: item.char.tag || '',
        },
        genre: {
          name: item.genre.name,
          mood: item.genre.mood || '',
          color: item.genre.color || '#ffa110',
        },
        setting: {
          name: item.setting.name,
        },
        hook: item.hook,
      };
    }

    function downloadFile(filename: string, content: string, type: string) {
      const blob = new Blob([content], { type });
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = filename;
      link.click();
      URL.revokeObjectURL(url);
    }

    let currentText = INITIAL_TEXT;
    let currentItem = sanitizeItem(INITIAL_ITEM) || generate();
    const seen = new Set<string>();
    let favorites = readStorage<any[]>(STORAGE_KEYS.favorites, []).map(sanitizeItem).filter(Boolean);

    function render(item: ReturnType<typeof generate>) {
      currentItem = sanitizeItem(item) || currentItem;
      const key = makeKey(item);
      if (seen.has(key)) return;
      seen.add(key);
      if (seen.size > 100) seen.clear();

      currentText = toText(item);

      const premiseText = document.getElementById('premiseText')!;
      const genreBadge = document.getElementById('genreBadge')!;
      const charTag = document.getElementById('charTag')!;

      premiseText.style.opacity = '0';
      premiseText.style.transform = 'translateY(10px)';

      setTimeout(() => {
        premiseText.textContent = currentText;
        genreBadge.innerHTML = `<span class="genre-name">${item.genre.name}</span><span class="genre-sep">/</span><span class="genre-mood">${item.genre.mood}</span>`;
        genreBadge.style.setProperty('--gc', item.genre.color);
        charTag.textContent = `#${item.char.tag}`;
        premiseText.style.opacity = '1';
        premiseText.style.transform = 'translateY(0)';
        syncFavoriteState();
      }, 150);
    }

    function syncFavoriteState() {
      const btn = document.getElementById('favoriteBtn');
      const status = document.getElementById('favoriteStatus');
      if (!btn || !status || !currentItem) return;
      const saved = favorites.some((item) => makeKey(item) === makeKey(currentItem));
      btn.setAttribute('aria-pressed', saved ? 'true' : 'false');
      btn.classList.toggle('active', saved);
      status.textContent = saved ? '已收藏到本地' : '未收藏';
    }

    function renderFavorites() {
      const list = document.getElementById('favoritesList');
      const empty = document.getElementById('favoritesEmpty');
      const summary = document.getElementById('favoritesSummary');
      if (!list || !empty || !summary) return;

      summary.textContent = `${favorites.length} 条已保存`;
      empty.hidden = favorites.length > 0;
      list.innerHTML = favorites.map((item, index) => `
        <article class="favorite-item" data-favorite-index="${index}">
          <div class="favorite-item-top">
            <span class="gallery-genre" style="color: ${item.genre.color}">${item.genre.name}</span>
            <div class="favorite-item-actions">
              <button class="mini-btn" data-action="load">恢复</button>
              <button class="mini-btn danger" data-action="remove">删除</button>
            </div>
          </div>
          <p>${toText(item)}</p>
        </article>
      `).join('');
      syncFavoriteState();
    }

    function saveFavorites() {
      writeStorage(STORAGE_KEYS.favorites, favorites);
      renderFavorites();
    }

    function toggleFavorite() {
      if (!currentItem) return;
      const key = makeKey(currentItem);
      const existingIndex = favorites.findIndex((item) => makeKey(item) === key);
      if (existingIndex >= 0) {
        favorites.splice(existingIndex, 1);
      } else {
        favorites = [currentItem, ...favorites];
      }
      saveFavorites();
    }

    function updateDailyStory() {
      const today = isoToday();
      const daily = getDailyStory(today);
      const dailyStoryText = document.getElementById('dailyStoryText');
      if (dailyStoryText) dailyStoryText.textContent = toText(daily);
    }

    function runStreak() {
      const today = isoToday();
      const streakCard = document.getElementById('streakCard');
      const streakCount = document.getElementById('streakCount');
      const streakHint = document.getElementById('streakHint');
      const saved = readStorage(STORAGE_KEYS.streak, {
        count: 0,
        lastVisit: '',
        milestones: [] as number[],
      });

      let count = saved.count || 0;
      if (!saved.lastVisit) {
        count = 1;
      } else {
        const delta = daysBetween(saved.lastVisit, today);
        if (delta === 1) count += 1;
        if (delta > 1) count = 1;
      }

      const milestones = Array.isArray(saved.milestones) ? saved.milestones : [];
      const isMilestone = (count === 7 || count === 30) && !milestones.includes(count);
      const nextState = {
        count,
        lastVisit: today,
        milestones: isMilestone ? [...milestones, count] : milestones,
      };

      writeStorage(STORAGE_KEYS.streak, nextState);

      if (streakCount) streakCount.textContent = String(count);
      if (streakHint) {
        streakHint.textContent = isMilestone
          ? `连续 ${count} 天，继续保持这个写作节奏。`
          : count > 1
            ? `你已经连续 ${count} 天打开 Story Spark。`
            : '今天第一次访问，开始积累灵感习惯。';
      }
      if (streakCard) streakCard.classList.toggle('celebrate', isMilestone);
    }

    function refreshGallery() {
      const grid = document.getElementById('galleryGrid');
      if (!grid) return;
      grid.innerHTML = [0, 1, 2].map(() => {
        const item = generate();
        return `<div class="gallery-item">
          <span class="gallery-genre" style="color: ${item.genre.color}">${item.genre.name}</span>
          <p>${item.char.name}，${item.setting.name}，${item.hook}。</p>
        </div>`;
      }).join('');
    }

    document.getElementById('generateBtn')?.addEventListener('click', () => {
      render(generate());
      refreshGallery();
    });

    document.getElementById('favoriteBtn')?.addEventListener('click', () => {
      toggleFavorite();
    });

    document.getElementById('copyBtn')?.addEventListener('click', () => {
      if (!currentText) {
        render(generate());
      }
      const text = `故事灵感来自 Story Spark\n\n${currentText}\n\nhttps://simpleeve.github.io/story-spark/`;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn')!;
        btn.innerHTML = '<svg class="btn-icon-sm" style="width:0.95em;height:0.95em;flex-shrink:0" aria-hidden="true"><use href="#icon-check"/></svg><span>已复制</span>';
        setTimeout(() => btn.innerHTML = '<svg class="btn-icon-sm" style="width:0.95em;height:0.95em;flex-shrink:0" aria-hidden="true"><use href="#icon-copy"/></svg><span>复制</span>', 1500);
      });
    });

    document.getElementById('shareBtn')?.addEventListener('click', () => {
      if (!currentText) {
        render(generate());
      }
      const text = `故事灵感\n\n${currentText}\n\n由 @StorySparkAI 生成\nhttps://simpleeve.github.io/story-spark/`;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    });

    document.querySelectorAll('.genre-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const genreName = (chip as HTMLElement).dataset.genre;
        const genre = GENRES.find((g: any) => g.name === genreName);
        if (!genre) return;
        render({ char: pick(CHARACTERS), genre, setting: pick(SETTINGS), hook: pick(HOOKS) });
        refreshGallery();
      });
    });

    // Keyboard shortcut: Space or Enter to regenerate
    document.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        if (document.activeElement?.tagName === 'BUTTON') return;
        e.preventDefault();
        render(generate());
        refreshGallery();
      }
    });

    document.getElementById('favoritesToggle')?.addEventListener('click', () => {
      const panel = document.getElementById('favoritesPanel');
      const toggle = document.getElementById('favoritesToggle');
      if (!panel || !toggle) return;
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      panel.hidden = expanded;
    });

    document.getElementById('favoritesList')?.addEventListener('click', (event) => {
      const target = event.target as HTMLElement;
      const button = target.closest('[data-action]') as HTMLElement | null;
      const item = target.closest('[data-favorite-index]') as HTMLElement | null;
      if (!button || !item) return;
      const index = Number(item.dataset.favoriteIndex);
      if (Number.isNaN(index) || !favorites[index]) return;

      if (button.dataset.action === 'load') {
        render(favorites[index]);
      }
      if (button.dataset.action === 'remove') {
        favorites.splice(index, 1);
        saveFavorites();
      }
    });

    document.getElementById('exportFavoritesBtn')?.addEventListener('click', () => {
      downloadFile(
        `story-spark-favorites-${isoToday()}.json`,
        JSON.stringify(favorites, null, 2),
        'application/json'
      );
    });

    document.getElementById('importFavoritesBtn')?.addEventListener('click', () => {
      document.getElementById('importFavoritesInput')?.click();
    });

    document.getElementById('importFavoritesInput')?.addEventListener('change', async (event) => {
      const input = event.currentTarget as HTMLInputElement;
      const file = input.files?.[0];
      if (!file) return;

      try {
        const text = await file.text();
        const parsed = JSON.parse(text);
        if (!Array.isArray(parsed)) throw new Error('Invalid favorites payload');
        const imported = parsed.map(sanitizeItem).filter(Boolean);
        const merged = [...favorites, ...imported].reduce((acc: any[], item) => {
          if (!acc.some((existing) => makeKey(existing) === makeKey(item))) acc.push(item);
          return acc;
        }, []);
        favorites = merged;
        saveFavorites();
      } catch {
        const empty = document.getElementById('favoritesEmpty');
        if (empty) {
          empty.hidden = false;
          empty.textContent = '导入失败，请检查 JSON 格式是否正确。';
        }
      } finally {
        input.value = '';
      }
    });

    updateDailyStory();
    runStreak();
    renderFavorites();
    syncFavoriteState();
  </script>

