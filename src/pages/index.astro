---
import Layout from '../layouts/Layout.astro';

const genres = ["奇幻", "科幻", "悬疑", "爱情", "恐怖", "冒险", "历史", "都市"];
const moods = ["温暖的", "黑暗的", "轻松的", "紧张的", "怀旧的", "讽刺的", "浪漫的", "荒诞的"];
const characters = [
  "一位独居的老人", "一对双胞胎", "一名记者", "一个神秘商人",
  "一位科学家", "一个孩子", "一位厨师", "一名侦探",
  "一个时间旅行者", "一位音乐家"
];
const settings = [
  "在一座废弃的空间站里", "在一个小镇的图书馆里", "在一艘跨越星际的飞船上",
  "在一个闹鬼的房子里", "在一个未来的城市中", "在一座古老的寺庙中",
  "在一个小小的咖啡馆里", "在一列穿越雪地的火车上"
];
const conflicts = [
  "发现了一个隐藏多年的秘密", "必须在24小时内做出选择", "被一个陌生人跟踪",
  "意外获得了一种超能力", "发现自己的记忆是假的", "被困在一个时间循环里",
  "要保护一个重要的证人", "发现了一个阴谋"
];

function pick(arr: string[]) {
  return arr[Math.floor(Math.random() * arr.length)];
}

const prompt = {
  genre: pick(genres),
  mood: pick(moods),
  character: pick(characters),
  setting: pick(settings),
  conflict: pick(conflicts),
};

const promptText = `${prompt.character}，在一个${prompt.mood}的${prompt.genre}故事中，${prompt.setting}${prompt.conflict}。`;
---

<Layout
  title="Story Spark - AI故事灵感生成器"
  description="免费AI故事灵感生成器，一键生成独特的奇幻、科幻、悬疑等故事设定。用于小说写作、剧本创作、DnD跑团、创意教学。无需注册，即开即用。"
>
  <main class="container">
    <header>
      <h1>✨ Story Spark</h1>
      <p class="subtitle">AI 故事灵感生成器 · 每次点击都是新世界</p>
    </header>

    <div class="prompt-card" id="promptCard">
      <p id="promptText">{promptText}</p>
    </div>

    <div class="prompt-data"
      data-genres={genres.join(",")}
      data-moods={moods.join(",")}
      data-characters={characters.join(",")}
      data-settings={settings.join(",")}
      data-conflicts={conflicts.join(",")}
    ></div>

    <button class="btn-generate" id="generateBtn">
      🔄 生成新灵感
    </button>

    <div class="share-buttons">
      <button class="btn-copy" id="copyBtn">📋 复制</button>
      <button class="btn-share" id="shareBtn">𝕏 分享</button>
    </div>

    <div class="tags">
      {genres.map(g => <span class="tag">{g}</span>)}
    </div>

    <footer>
      <p>📚 适用场景：小说写作 | 剧本创作 | DnD跑团 | 创意教学 | 游戏剧情</p>
      <p>免费工具 · 无需注册 · 即开即用</p>
    </footer>
  </main>

  <script>
    const genres = document.querySelector('.prompt-data')?.dataset.genres?.split(',') || [];
    const moods = document.querySelector('.prompt-data')?.dataset.moods?.split(',') || [];
    const characters = document.querySelector('.prompt-data')?.dataset.characters?.split(',') || [];
    const settings = document.querySelector('.prompt-data')?.dataset.settings?.split(',') || [];
    const conflicts = document.querySelector('.prompt-data')?.dataset.conflicts?.split(',') || [];

    function pick(arr: string[]) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function generate() {
      return `${pick(characters)}，在一个${pick(moods)}的${pick(genres)}故事中，${pick(settings)}${pick(conflicts)}。`;
    }

    const promptText = document.getElementById('promptText')!;
    const generateBtn = document.getElementById('generateBtn')!;
    const copyBtn = document.getElementById('copyBtn')!;
    const shareBtn = document.getElementById('shareBtn')!;

    generateBtn.addEventListener('click', () => {
      promptText.textContent = generate();
    });

    copyBtn.addEventListener('click', () => {
      const text = `📖 故事灵感：\n\n${promptText.textContent}\n\n✨ 由 Story Spark 生成`;
      navigator.clipboard.writeText(text).then(() => {
        copyBtn.textContent = '✅ 已复制';
        setTimeout(() => copyBtn.textContent = '📋 复制', 1500);
      });
    });

    shareBtn.addEventListener('click', () => {
      const text = `📖 故事灵感：\n\n${promptText.textContent}\n\n✨ 由 Story Spark 生成`;
      const url = window.location.href;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(url)}`, '_blank');
    });
  </script>

  <style>
    .container {
      max-width: 640px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
      text-align: center;
    }
    header h1 {
      font-size: 3rem;
      font-weight: 800;
      color: #d97706;
      margin-bottom: 0.5rem;
    }
    .subtitle {
      color: #6b7280;
      font-size: 0.9rem;
      margin-bottom: 2.5rem;
    }
    .prompt-card {
      background: #fffbeb;
      border: 2px solid #fde68a;
      border-radius: 1rem;
      padding: 1.5rem;
      font-size: 1.1rem;
      line-height: 1.8;
      color: #1f2937;
      margin-bottom: 1.5rem;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
      min-height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .prompt-card p {
      margin: 0;
    }
    .btn-generate {
      background: #d97706;
      color: white;
      font-size: 1.1rem;
      font-weight: 700;
      padding: 0.75rem 2.5rem;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(217,119,6,0.3);
      transition: all 0.2s;
      margin-bottom: 1rem;
    }
    .btn-generate:hover {
      background: #b45309;
      transform: scale(1.04);
      box-shadow: 0 6px 16px rgba(217,119,6,0.4);
    }
    .btn-generate:active {
      transform: scale(0.98);
    }
    .share-buttons {
      display: flex;
      gap: 0.75rem;
      justify-content: center;
      margin-bottom: 2rem;
    }
    .btn-copy, .btn-share {
      flex: 1;
      max-width: 160px;
      padding: 0.6rem 1rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 0.9rem;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
    }
    .btn-copy {
      background: #f3f4f6;
      color: #374151;
    }
    .btn-copy:hover {
      background: #e5e7eb;
    }
    .btn-share {
      background: #111827;
      color: white;
    }
    .btn-share:hover {
      background: #1f2937;
    }
    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .tag {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 9999px;
      padding: 0.25rem 0.75rem;
      font-size: 0.75rem;
      color: #6b7280;
    }
    footer {
      font-size: 0.75rem;
      color: #9ca3af;
      line-height: 1.8;
    }
    footer p:first-child {
      margin-bottom: 0.25rem;
    }
  </style>
</Layout>
