---
import Layout from '../layouts/Layout.astro';

// 精心设计的数据，确保叙事关联性
// 每次生成都是「人物在特定处境下的戏剧性瞬间」
const elements = {
  characters: [
    { name: "一位独居的老人", trait: "藏着秘密", tag: "老" },
    { name: "一对双胞胎", trait: "命运交织", tag: "双" },
    { name: "一名记者", trait: "追寻真相", tag: "记" },
    { name: "一个神秘商人", trait: "交易代价", tag: "商" },
    { name: "一位科学家", trait: "突破边界", tag: "科" },
    { name: "一个孩子", trait: "纯真视角", tag: "童" },
    { name: "一位厨师", trait: "隐喻人生", tag: "厨" },
    { name: "一名侦探", trait: "解谜破局", tag: "侦" },
    { name: "一个时间旅行者", trait: "悖论困境", tag: "时" },
    { name: "一位音乐家", trait: "共鸣救赎", tag: "乐" },
  ],
  genres: [
    { name: "奇幻", mood: "壮阔而神秘", color: "#a78bfa" },
    { name: "科幻", mood: "冷酷而深邃", color: "#60a5fa" },
    { name: "悬疑", mood: "紧张而窒息", color: "#f87171" },
    { name: "爱情", mood: "温柔而遗憾", color: "#fb7185" },
    { name: "恐怖", mood: "黑暗而寒冷", color: "#a3a3a3" },
    { name: "冒险", mood: "刺激而未知", color: "#34d399" },
    { name: "历史", mood: "厚重而沧桑", color: "#fbbf24" },
    { name: "都市", mood: "现实而迷惘", color: "#38bdf8" },
  ],
  settings: [
    { name: "在一座废弃的空间站里", tone: "孤立与宇宙的荒凉" },
    { name: "在一个小镇的图书馆里", tone: "知识的迷宫与时间的流逝" },
    { name: "在一艘跨越星际的飞船上", tone: "漫长的旅程与星际的孤独" },
    { name: "在一个闹鬼的房子里", tone: "过去的阴影与亡者的秘密" },
    { name: "在一个未来的城市中", tone: "霓虹灯下的赛博朋克" },
    { name: "在一座古老的寺庙中", tone: "冥想与武学的禅意" },
    { name: "在一个小小的咖啡馆里", tone: "日常中的非凡邂逅" },
    { name: "在一列穿越雪地的火车上", tone: "封闭空间里的张力" },
  ],
  hooks: [
    "发现了一个隐藏多年的秘密",
    "必须在24小时内做出选择",
    "被一个陌生人跟踪",
    "意外获得了一种超能力",
    "发现自己的记忆是假的",
    "被困在一个时间循环里",
    "要保护一个重要的证人",
    "发现了一个阴谋",
  ],
};

function pick<T>(arr: T[]): T {
  return arr[Math.floor(Math.random() * arr.length)];
}

function generate() {
  const char = pick(elements.characters);
  const genre = pick(elements.genres);
  const setting = pick(elements.settings);
  const hook = pick(elements.hooks);
  return { char, genre, setting, hook };
}

const initial = generate();
const initialText = `${initial.char.name}，${initial.setting.name}，${initial.hook}。`;
---

<Layout
  title="Story Spark — 故事灵感引擎"
  description="免费AI故事灵感生成器。输入一个随机种子，获得一个独特的故事 Premise。用于小说写作、剧本创作、DnD跑团。每日更新灵感。"
>
  <div class="noise-overlay"></div>

  <main>
    <header class="hero">
      <div class="logo-mark">✦</div>
      <h1>Story Spark</h1>
      <p class="tagline">故事灵感引擎 · 每次都是全新宇宙</p>
      <div class="stats">
        <span>8</span> 种故事类型
        <span>×</span>
        <span>10</span> 种人物原型
        <span>×</span>
        <span>8</span> 种场景
        <span>×</span>
        <span>8</span> 种戏剧冲突
        <span>=</span>
        <span>5,120</span> 种组合
      </div>
    </header>

    <div class="premise-card" id="premiseCard">
      <div class="genre-badge" id="genreBadge" style={`--genre-color: ${initial.genre.color}`}>
        {initial.genre.name}
        <span class="mood">{initial.genre.mood}</span>
      </div>
      <blockquote class="premise-text" id="premiseText">
        {initialText}
      </blockquote>
      <div class="char-tag" id="charTag">
        #{initial.char.tag}
      </div>
    </div>

    <div class="data-seed"
      data-characters={JSON.stringify(elements.characters)}
      data-genres={JSON.stringify(elements.genres)}
      data-settings={JSON.stringify(elements.settings)}
      data-hooks={JSON.stringify(elements.hooks)}
    ></div>

    <div class="actions">
      <button class="btn-generate" id="generateBtn">
        <span class="spark-icon">✦</span>
        生成新灵感
      </button>
    </div>

    <div class="share-row" id="shareRow" style="display:none">
      <button class="btn-copy" id="copyBtn">📋 复制</button>
      <button class="btn-share" id="shareBtn">𝕏 分享</button>
    </div>

    <div class="genre-grid" id="genreGrid">
      {elements.genres.map(g => (
        <button class="genre-chip" data-genre={g.name} style={`--c: ${g.color}`}>
          {g.name}
        </button>
      ))}
    </div>

    <div class="section-divider">⟡</div>

    <section class="gallery-section">
      <h2>灵感画廊</h2>
      <p class="gallery-desc">来自全球故事创作者的灵感碎片</p>
      <div class="gallery-grid" id="galleryGrid">
        <div class="gallery-item">
          <span class="gallery-genre">悬疑</span>
          <p>一位记者，在一艘跨越星际的飞船上，发现自己的记忆是假的。</p>
        </div>
        <div class="gallery-item">
          <span class="gallery-genre">奇幻</span>
          <p>一个孩子，在一个闹鬼的房子里，被一个陌生人跟踪。</p>
        </div>
        <div class="gallery-item">
          <span class="gallery-genre">科幻</span>
          <p>一名侦探，在一座废弃的空间站里，意外获得了一种超能力。</p>
        </div>
      </div>
      <p class="gallery-hint">灵感画廊 · 匿名展示 · 提交你自己的灵感</p>
    </section>

    <div class="section-divider">⟡</div>

    <section class="use-cases">
      <h2>谁在用 Story Spark</h2>
      <div class="use-case-grid">
        <div class="use-case">
          <div class="uc-icon">📖</div>
          <div class="uc-title">小说作者</div>
          <div class="uc-desc">打破写作瓶颈，找到下一个故事的核心 Premise</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎲</div>
          <div class="uc-title">DnD 跑团</div>
          <div class="uc-desc">快速生成情境设定，让玩家立即进入状态</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎬</div>
          <div class="uc-title">剧本创作</div>
          <div class="uc-desc">30秒获得一个故事核，专注叙事而不是开头的痛苦</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎮</div>
          <div class="uc-title">游戏策划</div>
          <div class="uc-desc">为游戏世界注入独特的背景设定和任务灵感</div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="footer-top">
        <div class="footer-brand">
          <span class="footer-logo">✦ Story Spark</span>
          <p>免费工具 · 无需注册 · 即开即用</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/SimpleEve/story-spark" target="_blank">GitHub</a>
          <span>·</span>
          <span>关于</span>
          <span>·</span>
          <span>联系我们</span>
        </div>
      </div>
      <div class="footer-ad">
        <p>📢 创作者工具推荐 · Story Spark 是免费工具，欢迎使用</p>
      </div>
      <p class="copyright">© 2026 Story Spark · 做世界上最好的故事灵感工具</p>
    </footer>
  </main>

  <script>
    const CHARACTERS = JSON.parse(document.querySelector('.data-seed')?.dataset.characters || '[]');
    const GENRES = JSON.parse(document.querySelector('.data-seed')?.dataset.genres || '[]');
    const SETTINGS = JSON.parse(document.querySelector('.data-seed')?.dataset.settings || '[]');
    const HOOKS = JSON.parse(document.querySelector('.data-seed')?.dataset.hooks || '[]');

    function pick(arr: any[]) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function generate() {
      const char = pick(CHARACTERS);
      const genre = pick(GENRES);
      const setting = pick(SETTINGS);
      const hook = pick(HOOKS);
      return { char, genre, setting, hook };
    }

    let currentText = '';

    function render(item: ReturnType<typeof generate>) {
      const text = `${item.char.name}，${item.setting.name}，${item.hook}。`;
      currentText = text;

      const premiseText = document.getElementById('premiseText')!;
      const genreBadge = document.getElementById('genreBadge')!;
      const charTag = document.getElementById('charTag')!;
      const shareRow = document.getElementById('shareRow')!;

      premiseText.style.opacity = '0';
      premiseText.style.transform = 'translateY(8px)';

      setTimeout(() => {
        premiseText.textContent = text;
        genreBadge.innerHTML = `${item.genre.name}<span class="mood">${item.genre.mood}</span>`;
        genreBadge.style.setProperty('--genre-color', item.genre.color);
        charTag.textContent = `#${item.char.tag}`;
        premiseText.style.opacity = '1';
        premiseText.style.transform = 'translateY(0)';
        shareRow.style.display = 'flex';
      }, 150);
    }

    document.getElementById('generateBtn')?.addEventListener('click', () => {
      render(generate());
    });

    document.getElementById('copyBtn')?.addEventListener('click', () => {
      const text = `📖 故事灵感来自 Story Spark ✦\n\n${currentText}\n\n👉 https://simpleeve.github.io/story-spark/`;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn')!;
        btn.textContent = '✅ 已复制';
        setTimeout(() => btn.textContent = '📋 复制', 1500);
      });
    });

    document.getElementById('shareBtn')?.addEventListener('click', () => {
      const text = `📖 故事灵感 ✦\n\n${currentText}\n\n✨ 由 @StorySparkAI 生成`;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    });

    // Filter by genre
    document.querySelectorAll('.genre-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const genreName = (chip as HTMLElement).dataset.genre;
        const genre = GENRES.find((g: any) => g.name === genreName);
        if (!genre) return;
        const char = pick(CHARACTERS);
        const setting = pick(SETTINGS);
        const hook = pick(HOOKS);
        render({ char, genre, setting, hook });
      });
    });
  </script>

  <style>
    :global(body) {
      background: #0c0c0e;
      color: #e5e5e5;
      min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    .noise-overlay {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 100;
      opacity: 0.025;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    }

    main {
      max-width: 700px;
      margin: 0 auto;
      padding: 0 1.5rem;
      position: relative;
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 4rem 0 2rem;
    }
    .logo-mark {
      font-size: 2rem;
      color: #d97706;
      margin-bottom: 0.5rem;
      animation: pulse 3s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    h1 {
      font-size: 3rem;
      font-weight: 800;
      background: linear-gradient(135deg, #fbbf24, #d97706);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .tagline {
      color: #737373;
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }
    .stats {
      font-size: 0.7rem;
      color: #525252;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .stats span {
      color: #d97706;
      font-weight: 700;
    }

    /* Premise Card */
    .premise-card {
      background: #161618;
      border: 1px solid #262626;
      border-radius: 1.25rem;
      padding: 2rem;
      margin: 2rem 0;
      text-align: center;
      position: relative;
      overflow: hidden;
      box-shadow: 0 0 60px rgba(217,119,6,0.06);
    }
    .premise-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(217,119,6,0.4), transparent);
    }
    .genre-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: color-mix(in srgb, var(--genre-color) 15%, transparent);
      border: 1px solid color-mix(in srgb, var(--genre-color) 30%, transparent);
      color: var(--genre-color);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.3rem 0.8rem;
      border-radius: 9999px;
      margin-bottom: 1.25rem;
    }
    .genre-badge .mood {
      color: #737373;
      font-weight: 400;
      text-transform: none;
      letter-spacing: 0;
    }
    .premise-text {
      font-size: 1.15rem;
      line-height: 2;
      color: #fafafa;
      font-weight: 400;
      margin: 0;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .char-tag {
      position: absolute;
      top: 1rem;
      right: 1.25rem;
      font-size: 0.65rem;
      color: #404040;
      letter-spacing: 0.05em;
    }

    /* Actions */
    .actions {
      text-align: center;
      margin-bottom: 1rem;
    }
    .btn-generate {
      background: linear-gradient(135deg, #d97706, #b45309);
      color: white;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.9rem 2.8rem;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      box-shadow: 0 0 30px rgba(217,119,6,0.25);
      transition: all 0.25s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .btn-generate:hover {
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 0 45px rgba(217,119,6,0.4);
    }
    .btn-generate:active {
      transform: scale(0.97);
    }
    .spark-icon {
      font-size: 1.1rem;
      transition: rotate 0.5s ease;
    }
    .btn-generate:hover .spark-icon {
      rotate: 20deg;
    }

    .share-row {
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 2.5rem;
    }
    .share-row {
      display: flex;
    }
    .btn-copy, .btn-share {
      flex: 1;
      max-width: 160px;
      padding: 0.6rem 1rem;
      border-radius: 0.75rem;
      font-weight: 600;
      font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.2s;
      border: 1px solid #262626;
    }
    .btn-copy {
      background: #1a1a1a;
      color: #a3a3a3;
    }
    .btn-copy:hover {
      background: #262626;
      color: #e5e5e5;
    }
    .btn-share {
      background: #111827;
      color: white;
    }
    .btn-share:hover {
      background: #1f2937;
    }

    /* Genre Grid */
    .genre-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 2.5rem;
    }
    .genre-chip {
      background: transparent;
      border: 1px solid #262626;
      color: #737373;
      border-radius: 9999px;
      padding: 0.3rem 0.9rem;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .genre-chip:hover {
      border-color: var(--c);
      color: var(--c);
      background: color-mix(in srgb, var(--c) 10%, transparent);
    }

    /* Divider */
    .section-divider {
      text-align: center;
      color: #2a2a2a;
      font-size: 1.2rem;
      margin: 3rem 0;
      letter-spacing: 0.5em;
    }

    /* Gallery */
    .gallery-section {
      margin-bottom: 3rem;
    }
    .gallery-section h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fafafa;
      text-align: center;
      margin-bottom: 0.3rem;
    }
    .gallery-desc {
      text-align: center;
      font-size: 0.75rem;
      color: #525252;
      margin-bottom: 1.5rem;
    }
    .gallery-grid {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .gallery-item {
      background: #111111;
      border: 1px solid #1f1f1f;
      border-radius: 0.75rem;
      padding: 1rem 1.25rem;
      text-align: left;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
    }
    .gallery-genre {
      font-size: 0.6rem;
      font-weight: 700;
      color: #d97706;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
      padding-top: 0.15rem;
    }
    .gallery-item p {
      font-size: 0.85rem;
      color: #a3a3a3;
      line-height: 1.6;
      margin: 0;
    }
    .gallery-hint {
      text-align: center;
      font-size: 0.65rem;
      color: #404040;
      margin-top: 1rem;
    }

    /* Use Cases */
    .use-cases {
      margin-bottom: 3rem;
    }
    .use-cases h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #fafafa;
      text-align: center;
      margin-bottom: 1.5rem;
    }
    .use-case-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .use-case {
      background: #111111;
      border: 1px solid #1a1a1a;
      border-radius: 0.75rem;
      padding: 1.25rem;
      text-align: left;
    }
    .uc-icon {
      font-size: 1.5rem;
      margin-bottom: 0.5rem;
    }
    .uc-title {
      font-size: 0.85rem;
      font-weight: 700;
      color: #e5e5e5;
      margin-bottom: 0.25rem;
    }
    .uc-desc {
      font-size: 0.75rem;
      color: #525252;
      line-height: 1.5;
    }

    /* Footer */
    .site-footer {
      border-top: 1px solid #1a1a1a;
      padding: 2.5rem 0 2rem;
      margin-top: 2rem;
    }
    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.5rem;
    }
    .footer-logo {
      font-size: 0.9rem;
      font-weight: 700;
      color: #d97706;
    }
    .footer-brand p {
      font-size: 0.7rem;
      color: #404040;
      margin-top: 0.25rem;
    }
    .footer-links {
      display: flex;
      gap: 0.5rem;
      font-size: 0.7rem;
      color: #404040;
      align-items: center;
    }
    .footer-links a {
      color: #525252;
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover {
      color: #a3a3a3;
    }
    .footer-ad {
      background: #111111;
      border: 1px solid #1f1f1f;
      border-radius: 0.5rem;
      padding: 0.6rem 1rem;
      font-size: 0.7rem;
      color: #404040;
      text-align: center;
      margin-bottom: 1rem;
    }
    .copyright {
      text-align: center;
      font-size: 0.65rem;
      color: #2a2a2a;
    }

    @media (max-width: 500px) {
      h1 { font-size: 2.2rem; }
      .use-case-grid { grid-template-columns: 1fr; }
      .footer-top { flex-direction: column; gap: 1rem; }
    }
  </style>
</Layout>
