---
import Layout from '../layouts/Layout.astro';

const elements = {
  characters: [
    { name: "一位独居的老人", tag: "老" },
    { name: "一对双胞胎", tag: "双" },
    { name: "一名记者", tag: "记" },
    { name: "一个神秘商人", tag: "商" },
    { name: "一位科学家", tag: "科" },
    { name: "一个孩子", tag: "童" },
    { name: "一位厨师", tag: "厨" },
    { name: "一名侦探", tag: "侦" },
    { name: "一个时间旅行者", tag: "时" },
    { name: "一位音乐家", tag: "乐" },
  ],
  genres: [
    { name: "奇幻", mood: "壮阔而神秘", color: "#a78bfa" },
    { name: "科幻", mood: "冷酷而深邃", color: "#60a5fa" },
    { name: "悬疑", mood: "紧张而窒息", color: "#f87171" },
    { name: "爱情", mood: "温柔而遗憾", color: "#fb7185" },
    { name: "恐怖", mood: "黑暗而寒冷", color: "#a3a3a3" },
    { name: "冒险", mood: "刺激而未知", color: "#34d399" },
    { name: "历史", mood: "厚重而沧桑", color: "#fbbf24" },
    { name: "都市", mood: "现实而迷惘", color: "#38bdf8" },
  ],
  settings: [
    { name: "在一座废弃的空间站里" },
    { name: "在一个小镇的图书馆里" },
    { name: "在一艘跨越星际的飞船上" },
    { name: "在一个闹鬼的房子里" },
    { name: "在一个未来的城市中" },
    { name: "在一座古老的寺庙中" },
    { name: "在一个小小的咖啡馆里" },
    { name: "在一列穿越雪地的火车上" },
  ],
  hooks: [
    "发现了一个隐藏多年的秘密",
    "必须在24小时内做出选择",
    "被一个陌生人跟踪",
    "意外获得了一种超能力",
    "发现自己的记忆是假的",
    "被困在一个时间循环里",
    "要保护一个重要的证人",
    "发现了一个阴谋",
  ],
};

function pick<T>(arr: T[]): T {
  return arr[Math.floor(Math.random() * arr.length)];
}

function generate() {
  return {
    char: pick(elements.characters),
    genre: pick(elements.genres),
    setting: pick(elements.settings),
    hook: pick(elements.hooks),
  };
}

// Generate 3 gallery items (fixed, show richness)
const gallery = [
  generate(),
  generate(),
  generate(),
];

const initial = generate();
const initialText = `${initial.char.name}，${initial.setting.name}，${initial.hook}。`;
---

<Layout
  title="Story Spark — 故事灵感引擎"
  description="免费故事灵感生成器。一键生成独特的奇幻、科幻、悬疑等故事 Premise。用于小说写作、剧本创作、DnD跑团。5,120 种组合，即开即用，完全免费。"
>
  <main>
    <!-- HERO -->
    <header class="hero">
      <div class="hero-eyebrow">CREATIVE WRITING TOOL</div>
      <h1 class="hero-title">STORY<br/>SPARK</h1>
      <p class="hero-sub">故事灵感引擎 · 每次都是全新宇宙</p>
      <div class="hero-stats">
        <span class="stat-num">8</span><span class="stat-label">类型</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">10</span><span class="stat-label">人物</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">8</span><span class="stat-label">场景</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">8</span><span class="stat-label">冲突</span>
        <span class="stat-sep">=</span>
        <span class="stat-num accent">5,120</span>
      </div>
    </header>

    <!-- PREMISE CARD -->
    <div class="premise-block">
      <div class="premise-card" id="premiseCard">
        <div class="premise-card-inner">
          <div class="premise-top">
            <div class="genre-badge" id="genreBadge" style={`--gc: ${initial.genre.color}`}>
              <span class="genre-name">{initial.genre.name}</span>
              <span class="genre-sep">/</span>
              <span class="genre-mood">{initial.genre.mood}</span>
            </div>
            <div class="char-tag" id="charTag">#{initial.char.tag}</div>
          </div>
          <blockquote class="premise-text" id="premiseText">
            {initialText}
          </blockquote>
        </div>
      </div>

      <!-- Seed data (hidden) -->
      <div class="data-seed"
        data-characters={JSON.stringify(elements.characters)}
        data-genres={JSON.stringify(elements.genres)}
        data-settings={JSON.stringify(elements.settings)}
        data-hooks={JSON.stringify(elements.hooks)}
        data-gallery={JSON.stringify(gallery)}
      ></div>

      <!-- ACTIONS -->
      <div class="actions-row">
        <button class="btn-generate" id="generateBtn">
          <span class="btn-icon">✦</span>
          <span>生成新灵感</span>
        </button>
      </div>

      <div class="share-row">
        <button class="btn-copy" id="copyBtn">
          <span class="btn-icon-sm">📋</span>复制
        </button>
        <button class="btn-share" id="shareBtn">
          <span class="btn-icon-sm">𝕏</span>分享
        </button>
      </div>

      <!-- Keyboard hint -->
      <div class="kb-hint">按 <kbd>SPACE</kbd> 或 <kbd>ENTER</kbd> 快速生成</div>
    </div>

    <!-- GENRE FILTER -->
    <div class="section-label">筛选类型</div>
    <div class="genre-grid" id="genreGrid">
      {elements.genres.map(g => (
        <button class="genre-chip" data-genre={g.name} style={`--gc: ${g.color}`}>
          {g.name}
        </button>
      ))}
    </div>

    <div class="rule"></div>

    <!-- GALLERY -->
    <section class="gallery-section">
      <div class="section-label">灵感画廊</div>
      <p class="section-desc">5,120 种组合，每次刷新都不一样</p>
      <div class="gallery-grid" id="galleryGrid">
        {gallery.map((item, i) => (
          <div class="gallery-item" data-gallery-index={i}>
            <span class="gallery-genre" style={`color: ${item.genre.color}`}>{item.genre.name}</span>
            <p>{item.char.name}，{item.setting.name}，{item.hook}。</p>
          </div>
        ))}
      </div>
    </section>

    <div class="rule"></div>

    <!-- USE CASES -->
    <section class="use-cases">
      <div class="section-label">谁在用</div>
      <div class="use-case-grid">
        <div class="use-case">
          <div class="uc-icon">📖</div>
          <div class="uc-title">小说作者</div>
          <div class="uc-desc">打破写作瓶颈，找到下一个故事的核心 Premise</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎲</div>
          <div class="uc-title">DnD 跑团</div>
          <div class="uc-desc">快速生成情境设定，让玩家立即进入状态</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎬</div>
          <div class="uc-title">剧本创作</div>
          <div class="uc-desc">30秒获得一个故事核，专注叙事而不是开头的痛苦</div>
        </div>
        <div class="use-case">
          <div class="uc-icon">🎮</div>
          <div class="uc-title">游戏策划</div>
          <div class="uc-desc">为游戏世界注入独特的背景设定和任务灵感</div>
        </div>
      </div>
    </section>

    <div class="rule"></div>

    <!-- WHY -->
    <section class="why-section">
      <div class="section-label">为什么有效</div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-num">01</div>
          <div class="why-body">
            <div class="why-title">结构化随机</div>
            <div class="why-desc">不是随机文字，而是精心设计的故事元素组合，每个 Premise 都有叙事逻辑</div>
          </div>
        </div>
        <div class="why-item">
          <div class="why-num">02</div>
          <div class="why-body">
            <div class="why-title">即时满足</div>
            <div class="why-desc">点击即生成，不需要注册、不需要等待，打开就用</div>
          </div>
        </div>
        <div class="why-item">
          <div class="why-num">03</div>
          <div class="why-body">
            <div class="why-title">无限组合</div>
            <div class="why-desc">5,120 种组合足够你用很久，而且还在持续迭代</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="footer-logo">✦ STORY SPARK</span>
          <p>免费工具 · 无需注册 · 即开即用</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/SimpleEve/story-spark" target="_blank" rel="noopener">GitHub</a>
          <span class="footer-dot">·</span>
          <a href="/story-spark/privacy">隐私政策</a>
        </div>
      </div>
      <div class="footer-copy">© 2026 Story Spark · 做世界上最好的故事灵感工具</div>
    </footer>
  </main>

  <script>
    const CHARACTERS = JSON.parse(document.querySelector('.data-seed')?.dataset.characters || '[]');
    const GENRES = JSON.parse(document.querySelector('.data-seed')?.dataset.genres || '[]');
    const SETTINGS = JSON.parse(document.querySelector('.data-seed')?.dataset.settings || '[]');
    const HOOKS = JSON.parse(document.querySelector('.data-seed')?.dataset.hooks || '[]');

    function pick(arr: any[]) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function makeKey(item: any) {
      return `${item.char.name}|${item.genre.name}|${item.setting.name}|${item.hook}`;
    }

    function generate() {
      return {
        char: pick(CHARACTERS),
        genre: pick(GENRES),
        setting: pick(SETTINGS),
        hook: pick(HOOKS),
      };
    }

    let currentText = '';
    const seen = new Set<string>();

    function render(item: ReturnType<typeof generate>) {
      const key = makeKey(item);
      if (seen.has(key)) return;
      seen.add(key);
      if (seen.size > 100) seen.clear();

      currentText = `${item.char.name}，${item.setting.name}，${item.hook}。`;

      const premiseText = document.getElementById('premiseText')!;
      const genreBadge = document.getElementById('genreBadge')!;
      const charTag = document.getElementById('charTag')!;

      premiseText.style.opacity = '0';
      premiseText.style.transform = 'translateY(10px)';

      setTimeout(() => {
        premiseText.textContent = currentText;
        genreBadge.innerHTML = `<span class="genre-name">${item.genre.name}</span><span class="genre-sep">/</span><span class="genre-mood">${item.genre.mood}</span>`;
        genreBadge.style.setProperty('--gc', item.genre.color);
        charTag.textContent = `#${item.char.tag}`;
        premiseText.style.opacity = '1';
        premiseText.style.transform = 'translateY(0)';
      }, 150);
    }

    function refreshGallery() {
      const grid = document.getElementById('galleryGrid');
      if (!grid) return;
      grid.innerHTML = [0, 1, 2].map(() => {
        const item = generate();
        return `<div class="gallery-item">
          <span class="gallery-genre" style="color: ${item.genre.color}">${item.genre.name}</span>
          <p>${item.char.name}，${item.setting.name}，${item.hook}。</p>
        </div>`;
      }).join('');
    }

    document.getElementById('generateBtn')?.addEventListener('click', () => {
      render(generate());
      refreshGallery();
    });

    document.getElementById('copyBtn')?.addEventListener('click', () => {
      const text = `📖 故事灵感来自 Story Spark ✦\n\n${currentText}\n\n👉 https://simpleeve.github.io/story-spark/`;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn')!;
        btn.textContent = '✅ 已复制';
        setTimeout(() => btn.innerHTML = '<span class="btn-icon-sm">📋</span>复制', 1500);
      });
    });

    document.getElementById('shareBtn')?.addEventListener('click', () => {
      const text = `📖 故事灵感 ✦\n\n${currentText}\n\n✨ 由 @StorySparkAI 生成\n👉 https://simpleeve.github.io/story-spark/`;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    });

    document.querySelectorAll('.genre-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const genreName = (chip as HTMLElement).dataset.genre;
        const genre = GENRES.find((g: any) => g.name === genreName);
        if (!genre) return;
        render({ char: pick(CHARACTERS), genre, setting: pick(SETTINGS), hook: pick(HOOKS) });
        refreshGallery();
      });
    });

    // Keyboard shortcut: Space or Enter to regenerate
    document.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        if (document.activeElement?.tagName === 'BUTTON') return;
        e.preventDefault();
        render(generate());
        refreshGallery();
      }
    });
  </script>

  <style>
    /* ═══════════════════════════════════════════
       MISTRAL DESIGN TOKENS — WARM GOLDEN UNIVERSE
    ═══════════════════════════════════════════ */
    :root {
      --yellow: #ffd900;
      --amber: #ffa110;
      --orange: #fa520f;
      --cream: #fffaeb;
      --cream-mid: #fff3cc;
      --dark-bg: #1a1206;
      --dark-surface: #241a08;
      --dark-elevated: #2e2009;
      --warm-shadow: rgba(127, 99, 21, 0.18);
      --warm-shadow-strong: rgba(127, 99, 21, 0.35);
      --text-primary: #fff8e8;
      --text-secondary: #c9a455;
      --text-muted: #7a5e20;
      --font: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
    }

    :global(*) {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :global(html) {
      scroll-behavior: smooth;
    }

    :global(body) {
      background: var(--dark-bg);
      color: var(--text-primary);
      font-family: var(--font);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Warm golden scrollbar */
    :global(::-webkit-scrollbar) {
      width: 6px;
    }
    :global(::-webkit-scrollbar-track) {
      background: var(--dark-bg);
    }
    :global(::-webkit-scrollbar-thumb) {
      background: var(--amber);
      border-radius: 0;
    }

    main {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ═══════════════════════════════════════════
       TYPOGRAPHY — MISTRAL STYLE
       Massive display headlines, negative tracking
    ═══════════════════════════════════════════ */
    .hero {
      padding: 5rem 0 3rem;
      text-align: center;
    }

    .hero-eyebrow {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1.25rem;
    }

    .hero-title {
      font-size: clamp(4rem, 14vw, 6.5rem);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.04em;
      text-transform: uppercase;
      background: linear-gradient(165deg, var(--yellow) 0%, var(--amber) 40%, var(--orange) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
    }

    .hero-sub {
      font-size: 0.8rem;
      color: var(--text-muted);
      letter-spacing: 0.12em;
      margin-bottom: 2.5rem;
    }

    .hero-stats {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
    }

    .stat-num {
      font-size: 1.1rem;
      font-weight: 900;
      color: var(--text-secondary);
      letter-spacing: -0.02em;
    }

    .stat-num.accent {
      color: var(--yellow);
      font-size: 1.3rem;
    }

    .stat-label {
      color: var(--text-muted);
    }

    .stat-sep {
      color: var(--warm-shadow-strong);
      font-weight: 300;
    }

    /* ═══════════════════════════════════════════
       SECTION LABELS — uppercase, tracked out
    ═══════════════════════════════════════════ */
    .section-label {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 1rem;
    }

    .section-desc {
      font-size: 0.72rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      margin-top: -0.5rem;
      letter-spacing: 0.04em;
    }

    /* ═══════════════════════════════════════════
       PREMISE BLOCK
    ═══════════════════════════════════════════ */
    .premise-block {
      margin-bottom: 3rem;
    }

    .premise-card {
      background: var(--dark-surface);
      border: 1px solid rgba(127, 99, 21, 0.25);
      border-radius: 0;
      overflow: hidden;
      margin-bottom: 1.5rem;
      position: relative;
      box-shadow:
        0 4px 24px var(--warm-shadow),
        0 1px 0 0 rgba(255, 217, 0, 0.06) inset;
    }

    /* Top accent line */
    .premise-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--yellow), var(--amber), var(--orange));
    }

    .premise-card-inner {
      padding: 2rem 1.75rem 1.75rem;
    }

    .premise-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 1.25rem;
    }

    .genre-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.3rem 0.7rem;
      border: 1px solid rgba(255, 217, 0, 0.2);
      background: rgba(255, 217, 0, 0.04);
      color: var(--gc, var(--amber));
      border-radius: 0;
    }

    .genre-sep {
      color: var(--text-muted);
      font-weight: 400;
    }

    .genre-mood {
      color: var(--text-muted);
      font-weight: 400;
      text-transform: none;
      letter-spacing: 0;
    }

    .char-tag {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      padding-top: 0.2rem;
    }

    .premise-text {
      font-size: 1.15rem;
      line-height: 2;
      color: var(--text-primary);
      font-weight: 400;
      letter-spacing: 0.01em;
      margin: 0;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    /* ═══════════════════════════════════════════
       ACTIONS ROW
    ═══════════════════════════════════════════ */
    .actions-row {
      text-align: center;
      margin-bottom: 1rem;
    }

    .btn-generate {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      background: linear-gradient(135deg, var(--amber) 0%, var(--orange) 100%);
      color: #fff;
      font-size: 0.8rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 1rem 2.5rem;
      border: none;
      border-radius: 0;
      cursor: pointer;
      box-shadow:
        0 4px 20px var(--warm-shadow-strong),
        0 0 0 1px rgba(255, 217, 0, 0.15);
      transition: all 0.2s ease;
    }

    .btn-generate:hover {
      transform: translateY(-2px);
      box-shadow:
        0 8px 32px var(--warm-shadow-strong),
        0 0 0 1px rgba(255, 217, 0, 0.3);
    }

    .btn-generate:active {
      transform: scale(0.97);
    }

    .btn-icon {
      font-size: 1rem;
    }

    .btn-generate:hover .btn-icon {
      animation: spin-spark 0.4s ease;
    }

    @keyframes spin-spark {
      from { transform: rotate(0deg); }
      to { transform: rotate(15deg); }
    }

    /* ═══════════════════════════════════════════
       SHARE ROW
    ═══════════════════════════════════════════ */
    .share-row {
      display: flex;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .btn-copy, .btn-share {
      flex: 1;
      max-width: 140px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.65rem 1rem;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      border-radius: 0;
      cursor: pointer;
      transition: all 0.18s ease;
      border: 1px solid rgba(127, 99, 21, 0.3);
      background: var(--dark-surface);
      color: var(--text-secondary);
    }

    .btn-copy:hover, .btn-share:hover {
      background: var(--dark-elevated);
      border-color: rgba(255, 161, 16, 0.5);
      color: var(--yellow);
    }

    .btn-share:hover {
      border-color: rgba(255, 217, 0, 0.5);
    }

    .btn-icon-sm {
      font-size: 0.85rem;
    }

    .kb-hint {
      text-align: center;
      font-size: 0.6rem;
      color: var(--text-muted);
      letter-spacing: 0.08em;
      margin-bottom: 2.5rem;
    }

    kbd {
      display: inline-block;
      background: var(--dark-elevated);
      border: 1px solid rgba(127, 99, 21, 0.3);
      border-radius: 0;
      padding: 0.1rem 0.4rem;
      font-family: var(--font);
      font-size: 0.58rem;
      color: var(--text-secondary);
    }

    /* ═══════════════════════════════════════════
       GENRE GRID
    ═══════════════════════════════════════════ */
    .genre-grid {
      display: flex;
