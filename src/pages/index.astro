---
import Layout from '../layouts/Layout.astro';

const elements = {
  characters: [
    { name: "一位独居的老人", tag: "老" },
    { name: "一对双胞胎", tag: "双" },
    { name: "一名记者", tag: "记" },
    { name: "一个神秘商人", tag: "商" },
    { name: "一位科学家", tag: "科" },
    { name: "一个孩子", tag: "童" },
    { name: "一位厨师", tag: "厨" },
    { name: "一名侦探", tag: "侦" },
    { name: "一个时间旅行者", tag: "时" },
    { name: "一位音乐家", tag: "乐" },
  ],
  genres: [
    { name: "奇幻", mood: "壮阔而神秘", color: "#a78bfa" },
    { name: "科幻", mood: "冷酷而深邃", color: "#60a5fa" },
    { name: "悬疑", mood: "紧张而窒息", color: "#f87171" },
    { name: "爱情", mood: "温柔而遗憾", color: "#fb7185" },
    { name: "恐怖", mood: "黑暗而寒冷", color: "#a3a3a3" },
    { name: "冒险", mood: "刺激而未知", color: "#34d399" },
    { name: "历史", mood: "厚重而沧桑", color: "#fbbf24" },
    { name: "都市", mood: "现实而迷惘", color: "#38bdf8" },
  ],
  settings: [
    { name: "在一座废弃的空间站里" },
    { name: "在一个小镇的图书馆里" },
    { name: "在一艘跨越星际的飞船上" },
    { name: "在一个闹鬼的房子里" },
    { name: "在一个未来的城市中" },
    { name: "在一座古老的寺庙中" },
    { name: "在一个小小的咖啡馆里" },
    { name: "在一列穿越雪地的火车上" },
  ],
  hooks: [
    "发现了一个隐藏多年的秘密",
    "必须在24小时内做出选择",
    "被一个陌生人跟踪",
    "意外获得了一种超能力",
    "发现自己的记忆是假的",
    "被困在一个时间循环里",
    "要保护一个重要的证人",
    "发现了一个阴谋",
  ],
};

function pick<T>(arr: T[]): T {
  return arr[Math.floor(Math.random() * arr.length)];
}

function generate() {
  return {
    char: pick(elements.characters),
    genre: pick(elements.genres),
    setting: pick(elements.settings),
    hook: pick(elements.hooks),
  };
}

// Generate 3 gallery items (fixed, show richness)
const gallery = [
  generate(),
  generate(),
  generate(),
];

const initial = generate();
const initialText = `${initial.char.name}，${initial.setting.name}，${initial.hook}。`;
---

<Layout
  title="Story Spark — 故事灵感引擎"
  description="免费故事灵感生成器。一键生成独特的奇幻、科幻、悬疑等故事 Premise。用于小说写作、剧本创作、DnD跑团。5,120 种组合，即开即用，完全免费。"
>
  <main>
    <!-- HERO -->
    <header class="hero">
      <div class="hero-eyebrow">CREATIVE WRITING TOOL</div>
      <h1 class="hero-title">STORY<br/>SPARK</h1>
      <p class="hero-sub">故事灵感引擎 · 每次都是全新宇宙</p>
      <div class="hero-stats">
        <span class="stat-num">8</span><span class="stat-label">类型</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">10</span><span class="stat-label">人物</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">8</span><span class="stat-label">场景</span>
        <span class="stat-sep">×</span>
        <span class="stat-num">8</span><span class="stat-label">冲突</span>
        <span class="stat-sep">=</span>
        <span class="stat-num accent">5,120</span>
      </div>
    </header>

    <!-- DAILY STRIP -->
    <div class="daily-strip">
      <div class="daily-story-card" id="dailyStoryCard">
        <div class="mini-label">今日故事</div>
        <div class="daily-story-content" id="dailyStoryContent">加载中...</div>
      </div>
      <div class="streak-card" id="streakCard">
        <div class="mini-label">连续访问</div>
        <div class="streak-value" id="streakValue">—</div>
        <div class="streak-unit">天</div>
      </div>
    </div>

    <!-- PREMISE CARD -->
    <div class="premise-block">
      <div class="premise-card" id="premiseCard">
        <div class="premise-card-inner">
          <div class="premise-top">
            <div class="genre-badge" id="genreBadge" style={`--gc: ${initial.genre.color}`}>
              <span class="genre-name">{initial.genre.name}</span>
              <span class="genre-sep">/</span>
              <span class="genre-mood">{initial.genre.mood}</span>
            </div>
            <div class="char-tag" id="charTag">#{initial.char.tag}</div>
          </div>
          <blockquote class="premise-text" id="premiseText">
            {initialText}
          </blockquote>
        </div>
      </div>

      <!-- Premise Meta: Favorite -->
      <div class="premise-meta" id="premiseMeta">
        <button class="btn-favorite" id="favoriteBtn">
          <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-heart"/></svg>
          <span id="favoriteLabel">收藏</span>
        </button>
        <span class="favorite-status" id="favoriteStatus"></span>
      </div>

      <!-- Seed data (hidden) -->
      <div class="data-seed"
        data-characters={JSON.stringify(elements.characters)}
        data-genres={JSON.stringify(elements.genres)}
        data-settings={JSON.stringify(elements.settings)}
        data-hooks={JSON.stringify(elements.hooks)}
        data-gallery={JSON.stringify(gallery)}
        data-initial-item={JSON.stringify(initial)}
      ></div>

      <!-- ACTIONS -->
      <div class="actions-row">
        <button class="btn-generate" id="generateBtn">
          <svg class="btn-icon" aria-hidden="true"><use href="#icon-spark"/></svg>
          <span>生成新灵感</span>
        </button>
      </div>

      <div class="share-row">
        <button class="btn-copy" id="copyBtn">
          <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-copy"/></svg><span>复制</span>
        </button>
        <button class="btn-share" id="shareBtn">
          <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-x"/></svg><span>分享</span>
        </button>
      </div>

      <!-- Keyboard hint -->
      <div class="kb-hint">按 <kbd>SPACE</kbd> 或 <kbd>ENTER</kbd> 快速生成</div>
    </div>

    <!-- GENRE FILTER -->
    <div class="section-label">筛选类型</div>
    <div class="genre-grid" id="genreGrid">
      {elements.genres.map(g => (
        <button class="genre-chip" data-genre={g.name} style={`--gc: ${g.color}`}>
          {g.name}
        </button>
      ))}
    </div>

    <div class="rule"></div>

    <!-- GALLERY -->
    <section class="gallery-section">
      <div class="section-label">灵感画廊</div>
      <p class="section-desc">5,120 种组合，每次刷新都不一样</p>
      <div class="gallery-grid" id="galleryGrid">
        {gallery.map((item, i) => (
          <div class="gallery-item" data-gallery-index={i}>
            <span class="gallery-genre" style={`color: ${item.genre.color}`}>{item.genre.name}</span>
            <p>{item.char.name}，{item.setting.name}，{item.hook}。</p>
          </div>
        ))}
      </div>
    </section>

    <div class="rule"></div>

    <!-- FAVORITES SECTION -->
    <section class="favorites-section" id="favoritesSection">
      <button class="favorites-toggle" id="favoritesToggle">
        <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-heart"/></svg>
        <span>收藏夹</span>
        <svg class="toggle-chevron" aria-hidden="true"><use href="#icon-chevron"/></svg>
      </button>
      <div class="favorites-panel" id="favoritesPanel">
        <div class="favorites-actions">
          <button class="btn-export" id="exportFavoritesBtn">导出 JSON</button>
          <button class="btn-import" id="importFavoritesBtn">导入 JSON</button>
          <input type="file" id="importFavoritesInput" accept=".json" style="display:none"/>
        </div>
        <div class="favorites-list" id="favoritesList"></div>
      </div>
    </section>

    <!-- HISTORY SECTION -->
    <section class="history-section" id="historySection">
      <button class="history-toggle" id="historyToggle">
        <svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-clock"/></svg>
        <span>生成历史</span>
        <svg class="toggle-chevron" aria-hidden="true"><use href="#icon-chevron"/></svg>
      </button>
      <div class="history-panel" id="historyPanel">
        <div class="history-list" id="historyList"></div>
      </div>
    </section>

    <!-- USE CASES -->
    <section class="use-cases">
      <div class="section-label">谁在用</div>
      <div class="use-case-grid">
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-book"/></svg>
          <div class="uc-title">小说作者</div>
          <div class="uc-desc">打破写作瓶颈，找到下一个故事的核心 Premise</div>
        </div>
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-dice"/></svg>
          <div class="uc-title">DnD 跑团</div>
          <div class="uc-desc">快速生成情境设定，让玩家立即进入状态</div>
        </div>
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-clapper"/></svg>
          <div class="uc-title">剧本创作</div>
          <div class="uc-desc">30秒获得一个故事核，专注叙事而不是开头的痛苦</div>
        </div>
        <div class="use-case">
          <svg class="uc-icon" aria-hidden="true"><use href="#icon-gamepad"/></svg>
          <div class="uc-title">游戏策划</div>
          <div class="uc-desc">为游戏世界注入独特的背景设定和任务灵感</div>
        </div>
      </div>
    </section>

    <div class="rule"></div>

    <!-- WHY -->
    <section class="why-section">
      <div class="section-label">为什么有效</div>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-num">01</div>
          <div class="why-body">
            <div class="why-title">结构化随机</div>
            <div class="why-desc">不是随机文字，而是精心设计的故事元素组合，每个 Premise 都有叙事逻辑</div>
          </div>
        </div>
        <div class="why-item">
          <div class="why-num">02</div>
          <div class="why-body">
            <div class="why-title">即时满足</div>
            <div class="why-desc">点击即生成，不需要注册、不需要等待，打开就用</div>
          </div>
        </div>
        <div class="why-item">
          <div class="why-num">03</div>
          <div class="why-body">
            <div class="why-title">无限组合</div>
            <div class="why-desc">5,120 种组合足够你用很久，而且还在持续迭代</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <svg style="display:inline-block;width:1em;height:1em;vertical-align:-0.1em" aria-hidden="true"><use href="#icon-spark"/></svg> STORY SPARK
          <p>免费工具 · 无需注册 · 即开即用</p>
        </div>
        <div class="footer-links">
          <a href="https://github.com/SimpleEve/story-spark" target="_blank" rel="noopener">GitHub</a>
          <span class="footer-dot">·</span>
          <a href="/story-spark/privacy">隐私政策</a>
        </div>
      </div>
      <div class="footer-copy">© 2026 Story Spark · 做世界上最好的故事灵感工具</div>
    </footer>
  </main>

  <script>
    const CHARACTERS = JSON.parse(document.querySelector('.data-seed')?.dataset.characters || '[]');
    const GENRES = JSON.parse(document.querySelector('.data-seed')?.dataset.genres || '[]');
    const SETTINGS = JSON.parse(document.querySelector('.data-seed')?.dataset.settings || '[]');
    const HOOKS = JSON.parse(document.querySelector('.data-seed')?.dataset.hooks || '[]');

    function pick(arr: any[]) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function makeKey(item: any) {
      return `${item.char.name}|${item.genre.name}|${item.setting.name}|${item.hook}`;
    }

    function generate() {
      return {
        char: pick(CHARACTERS),
        genre: pick(GENRES),
        setting: pick(SETTINGS),
        hook: pick(HOOKS),
      };
    }

    let currentText = '';
    let currentItem: ReturnType<typeof generate> | null = null;
    const seen = new Set<string>();

    function render(item: ReturnType<typeof generate>, skipHistory = false) {
      const key = makeKey(item);
      if (seen.has(key)) return;
      seen.add(key);
      if (seen.size > 100) seen.clear();

      currentText = `${item.char.name}，${item.setting.name}，${item.hook}。`;
      currentItem = item;

      const premiseText = document.getElementById('premiseText')!;
      const genreBadge = document.getElementById('genreBadge')!;
      const charTag = document.getElementById('charTag')!;

      premiseText.style.opacity = '0';
      premiseText.style.transform = 'translateY(10px)';

      setTimeout(() => {
        premiseText.textContent = currentText;
        genreBadge.innerHTML = `<span class="genre-name">${item.genre.name}</span><span class="genre-sep">/</span><span class="genre-mood">${item.genre.mood}</span>`;
        genreBadge.style.setProperty('--gc', item.genre.color);
        charTag.textContent = `#${item.char.tag}`;
        premiseText.style.opacity = '1';
        premiseText.style.transform = 'translateY(0)';

        // Sync favorite state
        syncFavoriteState();
      }, 150);

      // Save to history (skip on initial load)
      if (!skipHistory) {
        saveToHistory(item);
      }
    }

    function refreshGallery() {
      const grid = document.getElementById('galleryGrid');
      if (!grid) return;
      grid.innerHTML = [0, 1, 2].map(() => {
        const item = generate();
        return `<div class="gallery-item">
          <span class="gallery-genre" style="color: ${item.genre.color}">${item.genre.name}</span>
          <p>${item.char.name}，${item.setting.name}，${item.hook}。</p>
        </div>`;
      }).join('');
    }

    document.getElementById('generateBtn')?.addEventListener('click', () => {
      render(generate());
      refreshGallery();
    });

    document.getElementById('copyBtn')?.addEventListener('click', () => {
      const text = `故事灵感来自 Story Spark\n\n${currentText}\n\nhttps://simpleeve.github.io/story-spark/`;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn')!;
        btn.innerHTML = '<svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-check"/></svg><span>已复制</span>';
        setTimeout(() => btn.innerHTML = '<svg class="btn-icon-sm" aria-hidden="true"><use href="#icon-copy"/></svg><span>复制</span>', 1500);
      });
    });

    document.getElementById('shareBtn')?.addEventListener('click', () => {
      const text = `故事灵感\n\n${currentText}\n\n由 @StorySparkAI 生成\nhttps://simpleeve.github.io/story-spark/`;
      window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}`, '_blank');
    });

    document.querySelectorAll('.genre-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        const genreName = (chip as HTMLElement).dataset.genre;
        const genre = GENRES.find((g: any) => g.name === genreName);
        if (!genre) return;
        render({ char: pick(CHARACTERS), genre, setting: pick(SETTINGS), hook: pick(HOOKS) });
        refreshGallery();
      });
    });

    // Keyboard shortcut: Space or Enter to regenerate
    document.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Enter') {
        if (document.activeElement?.tagName === 'BUTTON') return;
        e.preventDefault();
        render(generate());
        refreshGallery();
      }
    });

    // ═══════════════════════════════════════════
    // PHASE 0.1 — FAVORITES SYSTEM
    // ═══════════════════════════════════════════
    const STORAGE_KEYS = {
      favorites: 'story-spark:favorites',
      streak: 'story-spark:streak',
      history: 'story-spark:history',
    };

    function readStorage(key: string) {
      try {
        return JSON.parse(localStorage.getItem(key) || '[]');
      } catch {
        return [];
      }
    }

    function writeStorage(key: string, data: any[]) {
      localStorage.setItem(key, JSON.stringify(data));
    }

    function sanitizeItem(str: string): string {
      return str.replace(/[&<>"']/g, (m) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      }[m] || m));
    }

    function getSafeColor(color: string): string {
      if (/^#[0-9a-fA-F]{6}$/.test(color)) return color;
      return '#ffa110';
    }

    function makeItemKey(item: any) {
      return `${item.char.name}|${item.genre.name}|${item.setting.name}|${item.hook}`;
    }

    function isFavorite(item: any): boolean {
      const favorites = readStorage(STORAGE_KEYS.favorites);
      const key = makeItemKey(item);
      return favorites.some((f: any) => makeItemKey(f) === key);
    }

    function toggleFavorite() {
      if (!currentItem) return;
      const favorites = readStorage(STORAGE_KEYS.favorites);
      const key = makeItemKey(currentItem);
      const idx = favorites.findIndex((f: any) => makeItemKey(f) === key);

      if (idx >= 0) {
        favorites.splice(idx, 1);
      } else {
        favorites.unshift({ ...currentItem, savedAt: Date.now() });
      }

      writeStorage(STORAGE_KEYS.favorites, favorites);
      syncFavoriteState();
      renderFavorites();
    }

    function syncFavoriteState() {
      const btn = document.getElementById('favoriteBtn');
      const label = document.getElementById('favoriteLabel');
      const status = document.getElementById('favoriteStatus');

      if (!btn || !label || !status || !currentItem) return;

      const isFav = isFavorite(currentItem);
      btn.classList.toggle('active', isFav);
      label.textContent = isFav ? '已收藏' : '收藏';
      status.textContent = isFav ? '★ 已存入收藏夹' : '';
    }

    function renderFavorites() {
      const list = document.getElementById('favoritesList');
      if (!list) return;

      const favorites = readStorage(STORAGE_KEYS.favorites);

      if (favorites.length === 0) {
        list.innerHTML = '<div class="empty-state">还没有收藏任何灵感</div>';
        return;
      }

      list.innerHTML = favorites.map((fav: any, idx: number) => `
        <div class="favorite-item" data-index="${idx}">
          <span class="favorite-item-genre" style="color: ${getSafeColor(fav.genre.color)}">${sanitizeItem(fav.genre.name)}</span>
          <span class="favorite-item-text">${sanitizeItem(fav.char.name)}，${sanitizeItem(fav.setting.name)}，${sanitizeItem(fav.hook)}。</span>
          <button class="favorite-item-delete" data-delete="${idx}">删除</button>
        </div>
      `).join('');

      // Click on item to load it
      list.querySelectorAll('.favorite-item').forEach(item => {
        item.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          if (target.classList.contains('favorite-item-delete')) return;
          const idx = parseInt((item as HTMLElement).dataset.index || '0');
          const favorites = readStorage(STORAGE_KEYS.favorites);
          if (favorites[idx]) {
            loadFromHistory(favorites[idx]);
          }
        });
      });

      // Delete handler
      list.querySelectorAll('.favorite-item-delete').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const idx = parseInt((btn as HTMLElement).dataset.delete || '0');
          const favorites = readStorage(STORAGE_KEYS.favorites);
          favorites.splice(idx, 1);
          writeStorage(STORAGE_KEYS.favorites, favorites);
          renderFavorites();
          syncFavoriteState();
        });
      });
    }

    // Export favorites
    function exportFavorites() {
      const favorites = readStorage(STORAGE_KEYS.favorites);
      const blob = new Blob([JSON.stringify(favorites, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'story-spark-favorites.json';
      a.click();
      URL.revokeObjectURL(url);
    }

    // Import favorites
    function importFavorites(file: File) {
      const reader = new FileReader();
      reader.onload = (e) => {
        try {
          const data = JSON.parse(e.target?.result as string);
          if (Array.isArray(data)) {
            const favorites = readStorage(STORAGE_KEYS.favorites);
            const existingKeys = new Set(favorites.map((f: any) => makeItemKey(f)));
            data.forEach((item: any) => {
              if (!existingKeys.has(makeItemKey(item))) {
                favorites.unshift({ ...item, savedAt: Date.now() });
              }
            });
            writeStorage(STORAGE_KEYS.favorites, favorites);
            renderFavorites();
            syncFavoriteState();
          }
        } catch (err) {
          console.error('Import failed:', err);
        }
      };
      reader.readAsText(file);
    }

    // ═══════════════════════════════════════════
    // PHASE 0.2 — STREAK & DAILY STORY
    // ═══════════════════════════════════════════
    function isoToday(): string {
      const d = new Date();
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    }

    function daysBetween(a: string, b: string): number {
      const msPerDay = 24 * 60 * 60 * 1000;
      return Math.round((new Date(b).getTime() - new Date(a).getTime()) / msPerDay);
    }

    function updateStreak() {
      const streakData = readStorage(STORAGE_KEYS.streak) || {};
      const today = isoToday();
      const lastVisit = streakData.lastVisit || '';

      let streak = streakData.streak || 0;

      if (lastVisit === today) {
        // Already visited today
      } else if (lastVisit && daysBetween(lastVisit, today) === 1) {
        streak += 1;
      } else if (lastVisit !== today) {
        streak = 1;
      }

      streakData.lastVisit = today;
      streakData.streak = streak;
      writeStorage(STORAGE_KEYS.streak, streakData);

      const streakValue = document.getElementById('streakValue');
      if (streakValue) {
        streakValue.textContent = String(streak);
      }
    }

    function hashString(str: string): number {
      let hash = 0;
      for (let i = 0; i < str.length; i++) {
        hash = ((hash << 5) - hash) + str.charCodeAt(i);
        hash |= 0;
      }
      return Math.abs(hash);
    }

    function seededPick<T>(arr: T[], seed: number): T {
      const idx = seed % arr.length;
      return arr[idx < 0 ? arr.length + idx : idx];
    }

    function getDailyStory() {
      const today = isoToday();
      const seed = hashString(today);
      return {
        char: seededPick(CHARACTERS, seed),
        genre: seededPick(GENRES, seed + 1000),
        setting: seededPick(SETTINGS, seed + 2000),
        hook: seededPick(HOOKS, seed + 3000),
      };
    }

    function renderDailyStory() {
      const daily = getDailyStory();
      const content = document.getElementById('dailyStoryContent');
      if (content) {
        content.textContent = `${daily.char.name}，${daily.setting.name}，${daily.hook}。`;
      }
    }

    // ═══════════════════════════════════════════
    // PHASE 0.3 — HISTORY
    // ═══════════════════════════════════════════
    function saveToHistory(item: any) {
      const history = readStorage(STORAGE_KEYS.history);
      const entry = { ...item, timestamp: Date.now() };

      // Avoid exact duplicates
      const existingIdx = history.findIndex((h: any) => makeItemKey(h) === makeItemKey(entry));
      if (existingIdx >= 0) {
        history.splice(existingIdx, 1);
      }

      history.unshift(entry);

      // Keep max 50 items
      if (history.length > 50) {
        history.splice(50);
      }

      writeStorage(STORAGE_KEYS.history, history);
      renderHistory();
    }

    function loadFromHistory(item: any) {
      currentItem = item;
      currentText = `${item.char.name}，${item.setting.name}，${item.hook}。`;

      const premiseText = document.getElementById('premiseText');
      const genreBadge = document.getElementById('genreBadge');
      const charTag = document.getElementById('charTag');

      if (premiseText) premiseText.textContent = currentText;
      if (genreBadge) {
        genreBadge.innerHTML = `<span class="genre-name">${item.genre.name}</span><span class="genre-sep">/</span><span class="genre-mood">${item.genre.mood}</span>`;
        genreBadge.style.setProperty('--gc', item.genre.color);
      }
      if (charTag) charTag.textContent = `#${item.char.tag}`;

      syncFavoriteState();
    }

    function renderHistory() {
      const list = document.getElementById('historyList');
      if (!list) return;

      const history = readStorage(STORAGE_KEYS.history);

      if (history.length === 0) {
        list.innerHTML = '<div class="empty-state">还没有生成历史</div>';
        return;
      }

      list.innerHTML = history.map((h: any, idx: number) => {
        const date = new Date(h.timestamp);
        const timeStr = `${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')} ${String(date.getHours()).padStart(2, '0')}:${String(date.getMinutes()).padStart(2, '0')}`;
        return `
          <div class="history-item" data-index="${idx}">
            <span class="history-item-time">${timeStr}</span>
            <span class="favorite-item-genre" style="color: ${getSafeColor(h.genre.color)}">${sanitizeItem(h.genre.name)}</span>
            <span class="history-item-text">${sanitizeItem(h.char.name)}，${sanitizeItem(h.setting.name)}，${sanitizeItem(h.hook)}。</span>
          </div>
        `;
      }).join('');

      list.querySelectorAll('.history-item').forEach(item => {
        item.addEventListener('click', () => {
          const idx = parseInt((item as HTMLElement).dataset.index || '0');
          const history = readStorage(STORAGE_KEYS.history);
          if (history[idx]) {
            loadFromHistory(history[idx]);
          }
        });
      });
    }

    // ═══════════════════════════════════════════
    // INITIALIZATION
    // ═══════════════════════════════════════════
    function init() {
      // Initialize daily story and streak
      renderDailyStory();
      updateStreak();

      // Load initial item from data attribute
      const dataSeed = document.querySelector('.data-seed');
      const initialItem = dataSeed ? (dataSeed as HTMLElement).dataset.initialItem : null;
      if (initialItem) {
        try {
          const item = JSON.parse(initialItem);
          currentItem = item;
          currentText = `${item.char.name}，${item.setting.name}，${item.hook}。`;
          syncFavoriteState();
        } catch (e) {
          // ignore parse errors
        }
      }

      // Render favorites and history
      renderFavorites();
      renderHistory();

      // Event listeners
      document.getElementById('favoriteBtn')?.addEventListener('click', toggleFavorite);

      document.getElementById('favoritesToggle')?.addEventListener('click', () => {
        const btn = document.getElementById('favoritesToggle');
        const panel = document.getElementById('favoritesPanel');
        btn?.classList.toggle('open');
        panel?.classList.toggle('open');
      });

      document.getElementById('historyToggle')?.addEventListener('click', () => {
        const btn = document.getElementById('historyToggle');
        const panel = document.getElementById('historyPanel');
        btn?.classList.toggle('open');
        panel?.classList.toggle('open');
      });

      document.getElementById('exportFavoritesBtn')?.addEventListener('click', exportFavorites);

      document.getElementById('importFavoritesBtn')?.addEventListener('click', () => {
        document.getElementById('importFavoritesInput')?.click();
      });

      document.getElementById('importFavoritesInput')?.addEventListener('change', (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) importFavorites(file);
      });
    }

    // Run init when DOM is ready
    init();
  </script>

